<%
  const isDbwHub = academy && academy.slug === "dbw-hub";

  const academyContent = isDbwHub
    ? {
        heroTitle: "DBW HUB",
        heroSubtitle: "Your Online Learning Platform",
        heroDescription:
          "A structured discipleship academy designed to help believers grow in biblical understanding, doctrine, and practical spiritual formation through guided levels, courses, materials, and assignments.",
        overviewTitle: "About DBW HUB",
        overviewText:
          "Discipleship by the Word [DBW] is presented as the discipleship arm/program of Town Crier Evangelical Ministries. The DBW syllabus says it was established in September 2022 by Livingstone Favour Akinadewo as a discipleship work “inspired out of fervent zeal and love for God.” It also says that, by the time the syllabus was written, DBW had been actively discipling teenagers, men, and women for about three years.",
        tracksTitle: "Learning Tracks",
        featuredTitle: "Featured Courses",
        statsText: "Structured, guided, and spiritually focused learning.",
        ctaTitle: "Ready to Begin Your Journey?",
        ctaText:
          "Start by signing in or registering. Once inside, you will be able to unlock levels, access courses, and submit your assignments.",
        emptyTrackText: "Learning tracks will appear here as levels are added by the admin.",
        emptyCourseText: "Featured courses will appear here once courses are published.",
      }
    : {
        heroTitle: "Davidic Harp",
        heroSubtitle: "Psalmist and Songwriting Academy",
        heroDescription:
          "A ministry academy dedicated to training students in singing, psalm writing, songwriting, and growth as effective vessels of musical expression before the Lord.",
        overviewTitle: "About Davidic Harp",
        overviewText:
          "Davidic Harp is a structured academy for students who desire to grow as psalmists, singers, and songwriters. Through guided levels, featured courses, study materials, and assignments, students are trained intentionally in musical expression and spiritual soundness.",
        tracksTitle: "Learning Tracks",
        featuredTitle: "Featured Courses",
        statsText: "Structured music, psalmist, and songwriting training.",
        ctaTitle: "Step Into Your Musical Training Journey",
        ctaText:
          "Sign in or register to continue into Davidic Harp, unlock levels, and begin your learning experience.",
        emptyTrackText: "Learning tracks will appear here as levels are added by the admin.",
        emptyCourseText: "Featured courses will appear here once courses are published.",
      };
%>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= academy.name %> | Academy</title>

  <link rel="icon" type="image/png" href="/images/tcem-logo.png" />
  <link rel="apple-touch-icon" href="/images/tcem-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />

  <style>
    .academy-detail-page {
      font-family: "Inter", sans-serif;
    }

    .academy-hero-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(3rem, 6vw, 5.3rem);
      line-height: 0.92;
      font-weight: 700;
      letter-spacing: -0.03em;
    }

    .academy-section-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(2.35rem, 4vw, 3.7rem);
      line-height: 0.96;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #111827;
    }

    .academy-card-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(1.9rem, 3vw, 2.5rem);
      line-height: 1;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #111827;
    }

    .academy-section-title--light {
      color: #ffffff !important;
    }

    @media (max-width: 767px) {
      .academy-hero-title {
        font-size: clamp(2.6rem, 11vw, 4rem);
      }
    }
  </style>
</head>
<body class="academy-detail-page bg-[#f7f7f8] text-gray-900">

  <%- include("../partials/header") %>

  <section class="bg-gradient-to-r from-[#4F46E5] via-[#7C3AED] to-[#C026D3] text-white">
    <div class="max-w-7xl mx-auto px-6 md:px-16 py-14 md:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-white/80 text-sm md:text-base font-medium mb-4">Ministry Academy</p>

          <h1 class="academy-hero-title mb-4">
            <%= academyContent.heroTitle %>
          </h1>

          <p class="text-xl md:text-3xl font-semibold text-white/90 mb-5">
            <%= academyContent.heroSubtitle %>
          </p>

          <p class="text-lg md:text-xl leading-relaxed text-white/90 max-w-3xl mb-8">
            <%= academyContent.heroDescription %>
          </p>

          <div class="flex flex-wrap gap-4">
            <% if (!isLoggedIn) { %>
              <a
                href="#"
                class="open-auth-modal inline-flex items-center justify-center rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition"
                data-modal-mode="login"
                data-academy-slug="<%= academy.slug %>"
                data-redirect-after-auth="/academy/<%= academy.slug %>"
              >
                Sign In / Register
              </a>
            <% } else if (!isEnrolledInAcademy && !isAdmin) { %>
              <form action="/academy/<%= academy.slug %>/join" method="POST">
                <button
                  type="submit"
                  class="inline-flex items-center justify-center rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition"
                >
                  Join This Academy
                </button>
              </form>
            <% } else { %>
              <a
                href="/academy/<%= academy.slug %>/courses"
                class="inline-flex items-center justify-center rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition"
              >
                Enter Courses
              </a>
            <% } %>

            <a
              href="/academy/<%= academy.slug %>/courses"
              class="inline-flex items-center justify-center rounded-2xl border border-white/30 text-white px-8 py-4 text-lg font-semibold hover:bg-white/10 transition"
            >
              Browse Courses
            </a>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="rounded-[26px] bg-white/10 backdrop-blur border border-white/15 p-6">
            <p class="text-sm uppercase tracking-wide text-white/75 mb-2">Levels</p>
            <p class="text-4xl md:text-5xl font-extrabold"><%= levelCount %></p>
          </div>

          <div class="rounded-[26px] bg-white/10 backdrop-blur border border-white/15 p-6">
            <p class="text-sm uppercase tracking-wide text-white/75 mb-2">Courses</p>
            <p class="text-4xl md:text-5xl font-extrabold"><%= courseCount %></p>
          </div>

          <div class="rounded-[26px] bg-white/10 backdrop-blur border border-white/15 p-6 sm:col-span-2">
            <p class="text-sm uppercase tracking-wide text-white/75 mb-2">Overview</p>
            <p class="text-lg md:text-xl leading-relaxed text-white/90">
              <%= academyContent.statsText %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-8 pb-2">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <% if (authStatus === "required") { %>
        <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-red-700 font-medium">
          Please sign in first before entering this academy.
        </div>
      <% } %>

      <% if (joinStatus === "required") { %>
        <div class="mb-6 rounded-2xl border border-blue-200 bg-blue-50 px-5 py-4 text-blue-700 font-medium">
          You are logged in, but you have not joined this academy yet.
        </div>
      <% } %>

      <% if (joinedStatus === "success") { %>
        <div class="mb-6 rounded-2xl border border-green-200 bg-green-50 px-5 py-4 text-green-700 font-medium">
          Academy joined successfully. You can now access the academy courses.
        </div>
      <% } %>
    </div>
  </section>

  <section class="py-14 md:py-16">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
        <h2 class="academy-section-title mb-5">
          <%= academyContent.overviewTitle %>
        </h2>
        <p class="text-lg md:text-[1.15rem] leading-relaxed text-slate-700 max-w-5xl">
          <%= academyContent.overviewText %>
        </p>
      </div>
    </div>
  </section>

  <section class="pb-14 md:pb-16">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="flex items-center justify-between gap-4 mb-8">
        <div>
          <h2 class="academy-section-title mb-2">
            <%= academyContent.tracksTitle %>
          </h2>
          <p class="text-lg text-slate-600">
            Explore the structured levels available inside <%= academy.name %>.
          </p>
        </div>
      </div>

      <% if (!learningTracks || !learningTracks.length) { %>
        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-10 text-center">
          <p class="text-lg text-slate-600"><%= academyContent.emptyTrackText %></p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
          <% learningTracks.forEach((track) => { %>
            <article class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8">
              <div class="flex items-center justify-between gap-4 mb-4">
                <h3 class="academy-card-title"><%= track.title %></h3>
                <% if (track.price) { %>
                  <span class="inline-flex rounded-full bg-purple-100 text-purple-700 px-4 py-2 text-sm font-semibold">
                    <%= track.price %>
                  </span>
                <% } %>
              </div>

              <p class="text-lg text-slate-700 leading-relaxed mb-5">
                <%= track.description || "A guided learning level inside this academy." %>
              </p>

              <div class="flex items-center justify-between text-base text-slate-600">
                <span><strong>Order:</strong> <%= track.order %></span>
                <span><strong>Courses:</strong> <%= track.courseCount %></span>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="pb-14 md:pb-16">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="flex items-center justify-between gap-4 mb-8">
        <div>
          <h2 class="academy-section-title mb-2">
            <%= academyContent.featuredTitle %>
          </h2>
          <p class="text-lg text-slate-600">
            Some of the published courses students can explore in this academy.
          </p>
        </div>

        <a
          href="/academy/<%= academy.slug %>/courses"
          class="hidden md:inline-flex items-center justify-center rounded-2xl bg-[#4F46E5] text-white px-6 py-3 font-semibold hover:bg-indigo-700 transition"
        >
          View All Courses
        </a>
      </div>

      <% if (!featuredCourses || !featuredCourses.length) { %>
        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-10 text-center">
          <p class="text-lg text-slate-600"><%= academyContent.emptyCourseText %></p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
          <% featuredCourses.forEach((course) => { %>
            <article class="bg-white border border-indigo-100 rounded-[26px] shadow-sm overflow-hidden <%= !course.isUnlocked ? 'opacity-95' : '' %>">
              <div class="relative h-56 overflow-hidden">
                <img
                  src="<%= course.image || '/images/event1.jpg' %>"
                  alt="<%= course.title %>"
                  class="w-full h-full object-cover <%= !course.isUnlocked ? 'grayscale-[20%]' : '' %>"
                />

                <% if (!course.isUnlocked && isLoggedIn && isEnrolledInAcademy) { %>
                  <div class="absolute top-4 left-4">
                    <span class="inline-flex rounded-full bg-white/95 text-gray-900 px-4 py-2 text-sm font-semibold shadow">
                      🔒 Locked Course
                    </span>
                  </div>
                <% } %>
              </div>

              <div class="p-6 md:p-7">
                <h3 class="academy-card-title mb-4 leading-snug">
                  <%= course.title %>
                </h3>

                <p class="text-lg leading-relaxed text-slate-700 mb-5 line-clamp-3">
                  <%= course.description %>
                </p>

                <div class="flex flex-wrap items-center gap-5 text-base text-slate-600 mb-5">
                  <span class="inline-flex items-center gap-2">
                    <span>🕒</span>
                    <%= course.duration || "Not specified" %>
                  </span>

                  <span class="inline-flex items-center gap-2">
                    <span>▶</span>
                    <%= course.lessons || "Not specified" %>
                  </span>
                </div>

                <% if (!isLoggedIn) { %>
                  <a
                    href="#"
                    class="open-auth-modal w-full inline-flex items-center justify-center rounded-2xl bg-[#6B46C1] text-white px-6 py-4 text-lg font-semibold hover:bg-purple-700 transition"
                    data-modal-mode="login"
                    data-academy-slug="<%= academy.slug %>"
                    data-redirect-after-auth="/academy/<%= academy.slug %>"
                  >
                    Sign In / Register
                  </a>
                <% } else if (!isEnrolledInAcademy && !isAdmin) { %>
                  <form action="/academy/<%= academy.slug %>/join" method="POST">
                    <button
                      type="submit"
                      class="w-full inline-flex items-center justify-center rounded-2xl bg-[#6B46C1] text-white px-6 py-4 text-lg font-semibold hover:bg-purple-700 transition"
                    >
                      Join This Academy
                    </button>
                  </form>
                <% } else if (course.isUnlocked) { %>
                  <a
                    href="/academy/<%= academy.slug %>/courses/<%= course.slug %>"
                    class="w-full inline-flex items-center justify-center rounded-2xl bg-[#4F46E5] text-white px-6 py-4 text-lg font-semibold hover:bg-indigo-700 transition"
                  >
                    View Course
                  </a>
                <% } else if (course.hasPendingRequest) { %>
                  <button
                    type="button"
                    class="w-full inline-flex items-center justify-center rounded-2xl bg-yellow-500 text-white px-6 py-4 text-lg font-semibold cursor-not-allowed"
                    disabled
                  >
                    Pending Verification
                  </button>
                <% } else if (course.level) { %>
                  <a
                    href="/academy/<%= academy.slug %>/manual-payment/levels/<%= course.level._id %>"
                    class="w-full inline-flex items-center justify-center rounded-2xl bg-[#6B46C1] text-white px-6 py-4 text-lg font-semibold hover:bg-purple-700 transition"
                  >
                    Pay Manually
                  </a>
                <% } else { %>
                  <a
                    href="/academy/<%= academy.slug %>/courses/<%= course.slug %>"
                    class="w-full inline-flex items-center justify-center rounded-2xl bg-[#4F46E5] text-white px-6 py-4 text-lg font-semibold hover:bg-indigo-700 transition"
                  >
                    View Course
                  </a>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="pb-20 md:pb-24">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-gradient-to-r from-[#4F46E5] via-[#7C3AED] to-[#C026D3] text-white p-8 md:p-12 shadow-sm">
        <h2 class="academy-section-title academy-section-title--light mb-4">
          <%= academyContent.ctaTitle %>
        </h2>
        <p class="text-lg md:text-[1.2rem] text-white/90 leading-relaxed max-w-4xl mb-8">
          <%= academyContent.ctaText %>
        </p>

        <div class="flex flex-wrap gap-4">
          <% if (!isLoggedIn) { %>
            <a
              href="#"
              class="open-auth-modal inline-flex items-center justify-center rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition"
              data-modal-mode="login"
              data-academy-slug="<%= academy.slug %>"
              data-redirect-after-auth="/academy/<%= academy.slug %>"
            >
              Sign In / Register
            </a>
          <% } else if (!isEnrolledInAcademy && !isAdmin) { %>
            <form action="/academy/<%= academy.slug %>/join" method="POST">
              <button
                type="submit"
                class="inline-flex items-center justify-center rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition"
              >
                Join This Academy
              </button>
            </form>
          <% } else { %>
            <a
              href="/academy/<%= academy.slug %>/courses"
              class="inline-flex items-center justify-center rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition"
            >
              Continue to Courses
            </a>
          <% } %>

          <a
            href="/academy/<%= academy.slug %>/courses"
            class="inline-flex items-center justify-center rounded-2xl border border-white/30 text-white px-8 py-4 text-lg font-semibold hover:bg-white/10 transition"
          >
            Browse Courses
          </a>
        </div>
      </div>
    </div>
  </section>

  <%- include("../partials/footer") %>
  <%- include("../partials/auth-modal") %>
  <script src="/js/auth-modal.js"></script>

</body>
</html>