<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Notifications</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("../partials/header") %>

  <section class="py-10 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
        <div>
          <h1 class="text-4xl font-extrabold text-gray-950 mb-2">Notifications</h1>
          <p class="text-lg text-slate-600">Stay updated with newly added courses, events, and important updates.</p>
        </div>

        <form action="/notifications/read-all" method="POST">
          <button
            type="submit"
            class="rounded-2xl bg-[#6B46C1] text-white px-5 py-3 font-semibold hover:bg-purple-700 transition"
          >
            Mark All as Read
          </button>
        </form>
      </div>

      <div class="bg-white border border-gray-100 rounded-[24px] shadow-sm overflow-hidden">
        <% if (!notifications.length) { %>
          <div class="p-10 text-center">
            <p class="text-2xl font-semibold text-gray-900 mb-2">No notifications yet</p>
            <p class="text-slate-600">New courses and events will appear here.</p>
          </div>
        <% } else { %>
          <% notifications.forEach((item, index) => { %>
            <div
              class="p-8 notification-row <%= index !== notifications.length - 1 ? 'border-b border-gray-100' : '' %>"
              data-notification-id="<%= item._id %>"
            >
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-5">
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3 mb-3">
                    <h2 class="text-2xl font-extrabold text-gray-950"><%= item.title %></h2>

                    <span class="notification-status inline-flex rounded-full px-3 py-1 text-sm font-semibold <%= item.isRead ? 'bg-gray-100 text-gray-600' : 'bg-blue-100 text-blue-700' %>">
                      <%= item.isRead ? "Read" : "Unread" %>
                    </span>

                    <span class="inline-flex rounded-full bg-purple-100 text-purple-700 px-3 py-1 text-sm font-semibold capitalize">
                      <%= item.type %>
                    </span>
                  </div>

                  <p class="text-base text-slate-700 mb-3"><%= item.message %></p>

                  <% if (item.academy) { %>
                    <p class="text-sm text-slate-500 mb-2"><strong>Academy:</strong> <%= item.academy.name %></p>
                  <% } %>

                  <p class="text-sm text-slate-500"><strong>Created:</strong> <%= item.createdAtFormatted %></p>
                </div>

                <div class="shrink-0">
                  <a
                    href="/notifications/<%= item._id %>/open"
                    class="notification-open-link inline-flex items-center justify-center rounded-2xl px-5 py-3 font-semibold transition <%= item.isRead ? 'bg-white border border-gray-200 text-gray-800 hover:border-[#6B46C1] hover:text-[#6B46C1]' : 'bg-[#6B46C1] text-white hover:bg-purple-700' %>"
                  >
                    <%= item.isRead ? "Open Again" : "Open Notification" %>
                  </a>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </section>

  <script>
    // Fix browser back-cache issue:
    // When user returns to this page using the back button,
    // force a fresh reload so the read state updates immediately.
    window.addEventListener("pageshow", function (event) {
      const navigationEntries = performance.getEntriesByType("navigation");
      const navType = navigationEntries.length ? navigationEntries[0].type : "";

      if (event.persisted || navType === "back_forward") {
        window.location.reload();
      }
    });

    // Optional polish:
    // Immediately change the clicked notification UI to "Read"
    // before navigating away, so the page feels more responsive.
    document.addEventListener("DOMContentLoaded", function () {
      const links = document.querySelectorAll(".notification-open-link");

      links.forEach((link) => {
        link.addEventListener("click", function () {
          const row = this.closest(".notification-row");
          if (!row) return;

          const statusBadge = row.querySelector(".notification-status");
          if (statusBadge) {
            statusBadge.textContent = "Read";
            statusBadge.className =
              "notification-status inline-flex rounded-full px-3 py-1 text-sm font-semibold bg-gray-100 text-gray-600";
          }

          this.textContent = "Open Again";
          this.className =
            "notification-open-link inline-flex items-center justify-center rounded-2xl px-5 py-3 font-semibold transition bg-white border border-gray-200 text-gray-800 hover:border-[#6B46C1] hover:text-[#6B46C1]";
        });
      });
    });
  </script>

</body>
</html>