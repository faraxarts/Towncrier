<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Events | Town Crier</title>
  <link rel="icon" type="image/png" href="/images/tcem-logo.png" />
  <link rel="apple-touch-icon" href="/images/tcem-logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />

  <style>
    .events-page {
      font-family: "Inter", sans-serif;
      background: #f7f7f8;
      color: #111827;
    }

    .events-connect-link {
      font-family: "Inter", sans-serif;
    }

    .events-hero-label {
      display: inline-block;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: #b3834d;
      margin-bottom: 0.9rem;
    }



    .events-hero-heading span {
      display: block;
    }

.events-hero-heading {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 0.45rem;
  flex-wrap: wrap;
  line-height: 1;
  margin-bottom: 1.2rem;
}

.events-hero-heading .events-hero-upcoming {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(3rem, 6.3vw, 5rem);
  line-height: 0.92;
  font-weight: 700;
  font-style: italic;
  letter-spacing: -0.03em;
  color: #6B46C1;
}

.events-hero-heading .events-hero-events {
  font-family: "Inter", sans-serif;
  font-size: clamp(3rem, 6vw, 5rem);
  line-height: 0.92;
  font-weight: 800;
  letter-spacing: -0.04em;
  color: #111827;
}
    .events-hero-subtext {
      font-size: 1.08rem;
      line-height: 1.85;
      color: #64748b;
      max-width: 760px;
      margin: 0 auto;
    }

    .events-empty-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(2.1rem, 4vw, 3rem);
      line-height: 1;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #111827;
      margin-bottom: 0.8rem;
    }

    .event-card {
      background: #ffffff;
      border: 1px solid rgba(15, 23, 42, 0.06);
      border-radius: 28px;
      box-shadow: 0 14px 36px rgba(15, 23, 42, 0.06);
      overflow: hidden;
      transition: transform 0.28s ease, box-shadow 0.28s ease;
    }

    .event-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 22px 48px rgba(15, 23, 42, 0.11);
    }

    .event-card-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(2rem, 3vw, 2.45rem);
      line-height: 0.98;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #111827;
      margin-bottom: 1rem;
    }

    .event-card-description {
      font-size: 1.02rem;
      line-height: 1.8;
      color: #475569;
      margin-bottom: 1.4rem;
    }

    .event-card-meta {
      font-size: 0.98rem;
      line-height: 1.8;
      color: #64748b;
      margin-bottom: 1.5rem;
    }

    .event-card-meta strong {
      color: #1f2937;
      font-weight: 700;
    }

    .event-category-badge {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      background: rgba(107, 70, 193, 0.1);
      color: #6B46C1;
      padding: 0.5rem 1rem;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .event-cta-button {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      border-radius: 18px;
      background: #6B46C1;
      color: #ffffff;
      padding: 0.9rem 1.3rem;
      font-weight: 700;
      transition: background-color 0.2s ease, transform 0.2s ease;
    }

    .event-cta-button:hover {
      background: #5b35b5;
      transform: translateY(-1px);
    }

@media (max-width: 767px) {
  .events-hero-heading {
    gap: 0.28rem;
  }

  .events-hero-subtext {
    font-size: 1rem;
    line-height: 1.75;
  }

  .event-card-title {
    font-size: 1.9rem;
  }
}
  </style>
</head>
<body class="events-page">

  <%- include("partials/header") %>

  <!-- CONNECT SUB NAV -->
  <section class="border-b border-gray-200 bg-transparent">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="flex items-center gap-8 overflow-x-auto">
        <a href="/events" class="events-connect-link inline-flex h-14 items-center border-b-2 border-[#6B46C1] text-[#6B46C1] font-semibold whitespace-nowrap">
          Events
        </a>
        <a href="/contact" class="events-connect-link inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#6B46C1] whitespace-nowrap transition">
          Contact
        </a>
      </div>
    </div>
  </section>

  <!-- HERO -->
  <section class="pt-12 md:pt-16 pb-14 md:pb-16">
    <div class="max-w-7xl mx-auto px-6 md:px-16 text-center">
      <p class="events-hero-label">Stay Connected</p>

<h1 class="events-hero-heading" aria-label="Upcoming Events">
  <span class="events-hero-upcoming">Upcoming</span>
  <span class="events-hero-events">Events</span>
</h1>

      <p class="events-hero-subtext">
        Stay connected with our conferences, meetings, discipleship gatherings, and ministry events.
      </p>
    </div>
  </section>

  <!-- EVENTS GRID -->
  <section class="pb-16 md:pb-20">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <% if (!events || !events.length) { %>
        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-10 text-center">
          <h2 class="events-empty-title">
            No events available yet
          </h2>
          <p class="text-lg text-slate-600">
            Upcoming events will appear here.
          </p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
          <% events.forEach((event) => { %>
            <article class="event-card">
              <div class="h-56 overflow-hidden">
                <img
                  src="<%= event.featuredImage || '/images/event1.jpg' %>"
                  alt="<%= event.title %>"
                  class="w-full h-full object-cover"
                />
              </div>

              <div class="p-7 md:p-8">
                <div class="flex items-center justify-between gap-4 mb-4">
                  <span class="event-category-badge">
                    <%= event.category || "General Event" %>
                  </span>
                </div>

                <h2 class="event-card-title">
                  <%= event.title %>
                </h2>

                <p class="event-card-description">
                  <%= event.shortDescription %>
                </p>

                <div class="event-card-meta">
                  <p><strong>Date:</strong> <%= event.eventDate || "To be announced" %></p>
                  <p><strong>Time:</strong> <%= event.eventTime || "To be announced" %></p>
                  <p><strong>Location:</strong> <%= event.location || "To be announced" %></p>
                </div>

                <a
                  href="/events/<%= event.slug %>"
                  class="event-cta-button"
                >
                  <%= event.buttonText || "Learn More" %>
                  <span class="text-xl leading-none">→</span>
                </a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <%- include("partials/footer") %>

</body>
</html>