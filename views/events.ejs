<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Events | Town Crier</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("partials/header") %>

  <!-- CONNECT SUB NAV -->
  <section class="border-b border-gray-200 bg-transparent">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="flex items-center gap-8 overflow-x-auto">
        <a href="/events" class="inline-flex h-14 items-center border-b-2 border-[#4F46E5] text-[#4F46E5] font-semibold whitespace-nowrap">
          Events
        </a>
        <a href="/contact" class="inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#4F46E5] whitespace-nowrap transition">
          Contact
        </a>
      </div>
    </div>
  </section>

  <!-- HERO -->
  <section class="pt-10 md:pt-14 pb-14 md:pb-16">
    <div class="max-w-7xl mx-auto px-6 md:px-16 text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-gray-950 mb-5">
        Upcoming Events
      </h1>
      <p class="text-lg md:text-2xl text-slate-600 max-w-4xl mx-auto leading-relaxed">
        Stay connected with our conferences, meetings, discipleship gatherings, and ministry events.
      </p>
    </div>
  </section>

  <!-- EVENTS GRID -->
  <section class="pb-16 md:pb-20">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <% if (!events || !events.length) { %>
        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-10 text-center">
          <h2 class="text-2xl md:text-3xl font-extrabold text-gray-950 mb-4">
            No events available yet
          </h2>
          <p class="text-lg text-slate-600">
            upcoming events will appear here.
          </p>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
          <% events.forEach((event) => { %>
            <article class="bg-white border border-gray-100 rounded-[28px] shadow-sm overflow-hidden hover:-translate-y-1 transition duration-300">
              <div class="h-56 overflow-hidden">
                <img
                  src="<%= event.featuredImage || '/images/event1.jpg' %>"
                  alt="<%= event.title %>"
                  class="w-full h-full object-cover"
                />
              </div>

              <div class="p-7 md:p-8">
                <div class="flex items-center justify-between gap-4 mb-4">
                  <span class="inline-flex rounded-full bg-purple-100 text-purple-700 px-4 py-1.5 text-sm font-semibold">
                    <%= event.category || "General Event" %>
                  </span>
                </div>

                <h2 class="text-2xl font-extrabold text-gray-950 mb-4 leading-snug">
                  <%= event.title %>
                </h2>

                <p class="text-lg leading-relaxed text-slate-700 mb-6">
                  <%= event.shortDescription %>
                </p>

                <div class="space-y-2 text-base text-slate-600 mb-7">
                  <p><strong>Date:</strong> <%= event.eventDate || "To be announced" %></p>
                  <p><strong>Time:</strong> <%= event.eventTime || "To be announced" %></p>
                  <p><strong>Location:</strong> <%= event.location || "To be announced" %></p>
                </div>

                <a
                  href="/events/<%= event.slug %>"
                  class="inline-flex items-center gap-3 rounded-2xl bg-[#6B46C1] text-white px-6 py-3 font-semibold hover:bg-purple-700 transition"
                >
                  <%= event.buttonText || "Learn More" %>
                  <span class="text-xl leading-none">→</span>
                </a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <%- include("partials/footer") %>

</body>
</html>