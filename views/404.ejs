<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Page Not Found | Town Crier</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">
  <%- include("partials/header") %>

  <section class="py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6 md:px-16 text-center">
      <div class="bg-white border border-gray-100 rounded-[30px] shadow-sm p-10 md:p-14">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#6B46C1] mb-4">Error 404</p>
        <h1 class="text-4xl md:text-6xl font-extrabold text-gray-950 mb-5">This page could not be found</h1>
        <p class="text-lg md:text-xl text-slate-600 leading-relaxed mb-8">
          <%= typeof message !== 'undefined' && message ? message : "The page you are looking for may have been moved, renamed, or removed." %>
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/" class="inline-flex items-center justify-center rounded-2xl bg-[#6B46C1] text-white px-6 py-3 font-semibold hover:bg-purple-700 transition">
            Go Home
          </a>
          <a href="/contact" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-6 py-3 font-semibold text-gray-800 hover:border-[#6B46C1] hover:text-[#6B46C1] transition">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <%- include("partials/footer") %>
</body>
</html>
