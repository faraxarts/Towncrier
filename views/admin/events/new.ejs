<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>New Event | Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <div class="min-h-screen lg:grid lg:grid-cols-[280px_1fr]">
    <%- include("../partials/admin-sidebar") %>

    <main class="px-6 py-8 md:px-10 lg:px-12">

  <section class="py-10 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-4xl font-extrabold text-gray-950 mb-2">Add New Event</h1>
          <p class="text-lg text-slate-600">Create a new event for the public events page.</p>
        </div>

        <a href="/admin/events" class="rounded-2xl bg-white border border-gray-200 px-5 py-3 font-semibold text-gray-800 hover:border-[#6B46C1] hover:text-[#6B46C1] transition">
          Back
        </a>
      </div>

      <form action="/admin/events" method="POST" enctype="multipart/form-data" class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-semibold mb-2">Event Title</label>
            <input name="title" type="text" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" required>
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2">Slug</label>
            <input name="slug" type="text" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" placeholder="leave blank to auto-generate">
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold mb-2">Featured Image</label>
          <input name="featuredImage" type="file" accept=".jpg,.jpeg,.png,.webp" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5">
        </div>

        <div>
          <label class="block text-sm font-semibold mb-2">Short Description</label>
          <textarea name="shortDescription" rows="4" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" required></textarea>
        </div>

        <div>
          <label class="block text-sm font-semibold mb-2">Full Description</label>
          <textarea name="fullDescription" rows="5" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5"></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label class="block text-sm font-semibold mb-2">Event Date</label>
            <input name="eventDate" type="text" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" placeholder="Saturday, May 18, 2026">
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2">Event Time</label>
            <input name="eventTime" type="text" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" placeholder="10:00 AM">
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2">Category</label>
            <input name="category" type="text" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" placeholder="Conference / Retreat / Bootcamp">
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold mb-2">Location</label>
          <input name="location" type="text" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" placeholder="Main Auditorium, Lagos">
        </div>

        <div>
          <label class="block text-sm font-semibold mb-2">Button Text</label>
          <input name="buttonText" type="text" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" value="Learn More">
        </div>

        <div class="flex flex-wrap gap-6">
          <label class="inline-flex items-center gap-3">
            <input type="checkbox" name="isPublished" checked>
            <span>Published</span>
          </label>
        </div>

        <button type="submit" class="rounded-2xl bg-[#6B46C1] text-white px-8 py-4 font-semibold hover:bg-purple-700 transition">
          Create Event
        </button>
      </form>
    </div>
  </section>

    </main>
  </div>

  <script src="/js/admin-shell.js"></script>
</body>
</html>