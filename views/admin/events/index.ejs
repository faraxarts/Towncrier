<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Events | Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <div class="min-h-screen lg:grid lg:grid-cols-[280px_1fr]">
    <%- include("../partials/admin-sidebar") %>

    <main class="px-6 py-8 md:px-10 lg:px-12">
      <section>
        <div class="max-w-7xl mx-auto">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
            <div>
              <h1 class="text-4xl font-extrabold text-gray-950 mb-2">Manage Events</h1>
              <p class="text-lg text-slate-600">Create, edit, publish, and delete events.</p>
            </div>

            <div class="flex gap-3 flex-wrap">
              <a href="/admin" class="rounded-2xl bg-white border border-gray-200 px-5 py-3 font-semibold text-gray-800 hover:border-[#6B46C1] hover:text-[#6B46C1] transition">
                Back to Dashboard
              </a>
              <a href="/admin/events/new" class="rounded-2xl bg-[#6B46C1] text-white px-5 py-3 font-semibold hover:bg-purple-700 transition">
                Add New Event
              </a>
            </div>
          </div>

          <div class="bg-white border border-gray-100 rounded-[24px] shadow-sm overflow-hidden">
            <% if (!events.length) { %>
              <div class="p-10 text-center">
                <p class="text-2xl font-semibold text-gray-900">No events created yet</p>
              </div>
            <% } else { %>
              <% events.forEach((event, index) => { %>
                <div class="p-8 <%= index !== events.length - 1 ? 'border-b border-gray-100' : '' %>">
                  <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
                    <div>
                      <div class="flex flex-wrap items-center gap-3 mb-3">
                        <h2 class="text-2xl font-extrabold text-gray-950"><%= event.title %></h2>
                        <span class="inline-flex rounded-full px-3 py-1 text-sm font-semibold <%= event.isPublished ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
                          <%= event.isPublished ? 'Published' : 'Draft' %>
                        </span>
                      </div>

                      <p class="text-base text-slate-500 mb-2"><strong>Slug:</strong> <%= event.slug %></p>
                      <p class="text-base text-slate-500 mb-2"><strong>Date:</strong> <%= event.eventDate || "Not set" %></p>
                      <p class="text-base text-slate-500 mb-2"><strong>Time:</strong> <%= event.eventTime || "Not set" %></p>
                      <p class="text-base text-slate-500 mb-2"><strong>Location:</strong> <%= event.location || "Not set" %></p>
                      <p class="text-base text-slate-500 mb-2"><strong>Category:</strong> <%= event.category || "General Event" %></p>
                      <p class="text-base text-slate-700 mt-4 max-w-4xl"><%= event.shortDescription %></p>
                    </div>

                    <div class="flex flex-wrap gap-3">
                      <a
                        href="/admin/events/<%= event._id %>/edit"
                        class="rounded-2xl bg-[#6B46C1] text-white px-5 py-3 font-semibold hover:bg-purple-700 transition"
                      >
                        Edit
                      </a>

                      <form action="/admin/events/<%= event._id %>/toggle-publish" method="POST">
                        <button
                          type="submit"
                          class="rounded-2xl bg-white border border-gray-200 px-5 py-3 font-semibold text-gray-800 hover:border-[#6B46C1] hover:text-[#6B46C1] transition"
                        >
                          <%= event.isPublished ? "Unpublish" : "Publish" %>
                        </button>
                      </form>

                      <form action="/admin/events/<%= event._id %>/delete" method="POST" onsubmit="return confirm('Delete this event?');">
                        <button
                          type="submit"
                          class="rounded-2xl bg-white border border-red-200 px-5 py-3 font-semibold text-red-600 hover:bg-red-50 transition"
                        >
                          Delete
                        </button>
                      </form>
                    </div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script src="/js/admin-shell.js"></script>
</body>
</html>