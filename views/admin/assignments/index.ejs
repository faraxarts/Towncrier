<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Assignment Submissions | Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <div class="min-h-screen lg:grid lg:grid-cols-[280px_1fr]">
    <%- include("../partials/admin-sidebar") %>

    <main class="px-6 py-8 md:px-10 lg:px-12">
  <section class="py-10 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
        <div>
          <h1 class="text-4xl font-extrabold text-gray-950 mb-2">Assignment Submissions</h1>
          <p class="text-lg text-slate-600">Review uploaded student assignments by academy.</p>
        </div>

        <a href="/admin" class="rounded-2xl bg-white border border-gray-200 px-5 py-3 font-semibold text-gray-800">
          Back to Dashboard
        </a>
      </div>

      <form method="GET" action="/admin/assignments" class="bg-white border border-gray-100 rounded-[24px] shadow-sm p-5 md:p-6 mb-8">
        <div class="flex flex-col md:flex-row gap-4 md:items-end">
          <div class="flex-1">
            <label class="block text-sm font-semibold mb-2">Filter by Academy</label>
            <select name="academy" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5">
              <option value="">All academies</option>
              <% academies.forEach((academy) => { %>
                <option value="<%= academy._id %>" <%= String(selectedAcademy) === String(academy._id) ? "selected" : "" %>>
                  <%= academy.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="flex gap-3">
            <button type="submit" class="rounded-2xl bg-[#6B46C1] text-white px-5 py-3 font-semibold hover:bg-purple-700 transition">
              Apply Filter
            </button>
            <a href="/admin/assignments" class="rounded-2xl bg-white border border-gray-200 px-5 py-3 font-semibold text-gray-800">
              Clear
            </a>
          </div>
        </div>
      </form>

      <div class="bg-white border border-gray-100 rounded-[24px] shadow-sm overflow-hidden">
        <% if (!submissions.length) { %>
          <div class="p-10 text-center">
            <p class="text-2xl font-semibold text-gray-900">No assignment submissions found</p>
          </div>
        <% } else { %>
          <% submissions.forEach((item, index) => { %>
            <div class="p-8 <%= index !== submissions.length - 1 ? 'border-b border-gray-100' : '' %>">
              <div class="flex flex-col xl:flex-row xl:items-start xl:justify-between gap-6">
                <div class="space-y-2">
                  <h2 class="text-2xl font-extrabold text-gray-950">
                    <%= item.assignmentTitle %>
                  </h2>

                  <p class="text-base text-slate-700"><strong>Student:</strong> <%= item.user ? item.user.name : "Unknown User" %></p>
                  <p class="text-base text-slate-700"><strong>Email:</strong> <%= item.user ? item.user.email : "N/A" %></p>
                  <p class="text-base text-slate-700"><strong>Academy:</strong> <%= item.course && item.course.academy ? item.course.academy.name : "N/A" %></p>
                  <p class="text-base text-slate-700"><strong>Course:</strong> <%= item.course ? item.course.title : "Unknown Course" %></p>
                  <p class="text-base text-slate-700"><strong>Status:</strong> <%= item.status || "Submitted" %></p>
                  <p class="text-base text-slate-700"><strong>Submitted At:</strong> <%= new Date(item.createdAt).toLocaleString() %></p>

                  <% if (item.submissionNote) { %>
                    <p class="text-base text-slate-700"><strong>Note:</strong> <%= item.submissionNote %></p>
                  <% } %>
                </div>

                <div class="flex flex-wrap gap-3">
                  <% if (item.file && item.file.fileUrl) { %>
                    <a
                      href="<%= item.file.fileUrl %>"
                      target="_blank"
                      class="rounded-2xl bg-[#6B46C1] text-white px-5 py-3 font-semibold hover:bg-purple-700 transition"
                    >
                      Open Submission
                    </a>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </section>
    </main>
  </div>

  <script src="/js/admin-shell.js"></script>
</body>
</html>