<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Level | Admin</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <div class="min-h-screen lg:grid lg:grid-cols-[280px_1fr]">
    <%- include("../partials/admin-sidebar") %>

    <main class="px-6 py-8 md:px-10 lg:px-12">
  <section class="py-10 px-6 md:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-4xl font-extrabold text-gray-950 mb-2">Edit Level</h1>
          <p class="text-lg text-slate-600"><%= level.title %></p>
        </div>
        <a href="/admin/levels<%= selectedAcademy ? `?academy=${selectedAcademy}` : '' %>" class="rounded-2xl bg-white border border-gray-200 px-5 py-3 font-semibold text-gray-800">Back</a>
      </div>

      <form action="/admin/levels/<%= level._id %>/update" method="POST" class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10 space-y-6">
        <input type="hidden" name="redirectAcademy" value="<%= selectedAcademy || '' %>">

        <div>
          <label class="block text-sm font-semibold mb-2">Academy</label>
          <select name="academy" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" required>
            <option value="">Select academy</option>
            <% academies.forEach((academy) => { %>
              <option value="<%= academy._id %>" <%= String(level.academy) === String(academy._id) ? "selected" : "" %>>
                <%= academy.name %>
              </option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-sm font-semibold mb-2">Level Title</label>
          <input name="title" type="text" value="<%= level.title %>" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" required>
        </div>

        <div>
          <label class="block text-sm font-semibold mb-2">Slug</label>
          <input name="slug" type="text" value="<%= level.slug %>" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5">
        </div>

        <div>
          <label class="block text-sm font-semibold mb-2">Description</label>
          <textarea name="description" rows="4" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5"><%= level.description || "" %></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label class="block text-sm font-semibold mb-2">Price in Naira</label>
            <input
              name="priceNaira"
              type="number"
              min="0"
              step="1"
              value="<%= level.priceNaira || 15000 %>"
              class="w-full rounded-2xl border border-gray-200 px-4 py-3.5"
              required
            >
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2">Price in Dollars</label>
            <input
              name="priceUsd"
              type="number"
              min="0"
              step="1"
              value="<%= level.priceUsd || '' %>"
              class="w-full rounded-2xl border border-gray-200 px-4 py-3.5"
              placeholder="Enter approved USD amount"
            >
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2">Order</label>
            <input name="order" type="number" min="1" value="<%= level.order %>" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5">
          </div>
        </div>

        <div class="rounded-2xl bg-gray-50 border border-gray-200 p-4">
          <p class="text-sm text-slate-600"><strong>Current Display Price:</strong> <%= level.price || "Not set" %></p>
        </div>

        <label class="inline-flex items-center gap-3">
          <input type="checkbox" name="isPublished" <%= level.isPublished ? "checked" : "" %>>
          <span>Published</span>
        </label>

        <button type="submit" class="rounded-2xl bg-[#6B46C1] text-white px-8 py-4 font-semibold">
          Update Level
        </button>
      </form>
    </div>
  </section>
    </main>
  </div>

  <script src="/js/admin-shell.js"></script>
</body>
</html>