<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= event.title %> | Town Crier</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-icon.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/images/favicon-icon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon-icon.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />

  <style>
    .event-detail-page {
      background: #f7f7f8;
      color: #111827;
      font-family: "Inter", sans-serif;
    }

    .event-detail-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(3rem, 6vw, 5.2rem);
      line-height: 0.92;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #111827;
    }

    .event-detail-section-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(2.3rem, 4vw, 3.6rem);
      line-height: 0.96;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #111827;
    }

    .event-detail-meta-title {
      font-family: "Cormorant Garamond", serif;
      font-size: 1.7rem;
      line-height: 1;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #111827;
      margin-bottom: 0.5rem;
    }

    .event-detail-description {
      font-size: 1.05rem;
      line-height: 1.9;
      color: #475569;
    }

    .event-detail-breadcrumb {
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #6B46C1;
    }

    .event-detail-subtext {
      font-size: clamp(1.05rem, 2vw, 1.35rem);
      line-height: 1.8;
      color: #64748b;
    }

    @media (max-width: 767px) {
      .event-detail-title {
        font-size: clamp(2.5rem, 10vw, 3.7rem);
      }

      .event-detail-section-title {
        font-size: clamp(2rem, 8vw, 2.8rem);
      }

      .event-detail-meta-title {
        font-size: 1.45rem;
      }

      .event-detail-description,
      .event-detail-subtext {
        font-size: 1rem;
        line-height: 1.75;
      }
    }
  </style>
</head>
<body class="event-detail-page">

  <%- include("partials/header") %>

  <section class="py-10 md:py-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-white border border-gray-100 shadow-sm overflow-hidden">
        <img
          src="<%= event.featuredImage || '/images/event1.jpg' %>"
          alt="<%= event.title %>"
          class="w-full h-[280px] md:h-[420px] object-cover"
        />

        <div class="p-8 md:p-12">
          <p class="event-detail-breadcrumb mb-4">
            <a href="/events" class="hover:underline">Events</a>
            <span class="mx-2">/</span>
            <span><%= event.category || "General Event" %></span>
          </p>

          <h1 class="event-detail-title mb-5">
            <%= event.title %>
          </h1>

          <p class="event-detail-subtext max-w-5xl mb-8">
            <%= event.shortDescription %>
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="rounded-[22px] bg-indigo-50 p-6">
              <h3 class="event-detail-meta-title">Date</h3>
              <p class="text-slate-700 text-lg"><%= event.eventDate || "To be announced" %></p>
            </div>

            <div class="rounded-[22px] bg-purple-50 p-6">
              <h3 class="event-detail-meta-title">Time</h3>
              <p class="text-slate-700 text-lg"><%= event.eventTime || "To be announced" %></p>
            </div>

            <div class="rounded-[22px] bg-pink-50 p-6">
              <h3 class="event-detail-meta-title">Location</h3>
              <p class="text-slate-700 text-lg"><%= event.location || "To be announced" %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 md:pb-20">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-12">
        <h2 class="event-detail-section-title mb-6">
          Event Details
        </h2>

        <p class="event-detail-description whitespace-pre-line">
          <%= event.fullDescription || event.shortDescription %>
        </p>

        <div class="mt-10">
          <a
            href="/contact"
            class="inline-flex items-center gap-3 rounded-2xl bg-[#6B46C1] text-white px-8 py-4 text-lg font-semibold hover:bg-purple-700 transition"
          >
            Contact for More Info
            <span class="text-2xl leading-none">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <%- include("partials/footer") %>

</body>
</html>