<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= event.title %> | Town Crier</title>
  <link rel="icon" type="image/png" href="/images/tcem-logo.png" />
<link rel="apple-touch-icon" href="/images/tcem-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("partials/header") %>

  <!-- HERO -->
  <section class="py-10 md:py-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-white border border-gray-100 shadow-sm overflow-hidden">
        <img
          src="<%= event.featuredImage || '/images/event1.jpg' %>"
          alt="<%= event.title %>"
          class="w-full h-[280px] md:h-[420px] object-cover"
        />

        <div class="p-8 md:p-12">
          <p class="text-sm md:text-base text-[#6B46C1] font-semibold mb-4">
            <a href="/events" class="hover:underline">Events</a>
            <span class="mx-2">/</span>
            <span><%= event.category || "General Event" %></span>
          </p>

          <h1 class="text-4xl md:text-6xl font-extrabold text-gray-950 mb-5">
            <%= event.title %>
          </h1>

          <p class="text-lg md:text-2xl text-slate-600 max-w-5xl leading-relaxed mb-8">
            <%= event.shortDescription %>
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="rounded-[22px] bg-indigo-50 p-6">
              <h3 class="text-lg font-bold text-gray-950 mb-2">Date</h3>
              <p class="text-slate-700 text-lg"><%= event.eventDate || "To be announced" %></p>
            </div>

            <div class="rounded-[22px] bg-purple-50 p-6">
              <h3 class="text-lg font-bold text-gray-950 mb-2">Time</h3>
              <p class="text-slate-700 text-lg"><%= event.eventTime || "To be announced" %></p>
            </div>

            <div class="rounded-[22px] bg-pink-50 p-6">
              <h3 class="text-lg font-bold text-gray-950 mb-2">Location</h3>
              <p class="text-slate-700 text-lg"><%= event.location || "To be announced" %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DESCRIPTION -->
  <section class="pb-16 md:pb-20">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-6">
          Event Details
        </h2>

        <p class="text-lg md:text-[1.15rem] leading-relaxed text-slate-700 whitespace-pre-line">
          <%= event.fullDescription || event.shortDescription %>
        </p>

        <div class="mt-10">
          <a
            href="/contact"
            class="inline-flex items-center gap-3 rounded-2xl bg-[#6B46C1] text-white px-8 py-4 text-lg font-semibold hover:bg-purple-700 transition"
          >
            Contact for More Info
            <span class="text-2xl leading-none">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <%- include("partials/footer") %>

</body>
</html>