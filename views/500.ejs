<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : "Server Error" %> | Town Crier</title>
  <link rel="icon" type="image/png" href="/images/tcem-logo.png" />
  <link rel="apple-touch-icon" href="/images/tcem-logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />

  <style>
    .error-page {
      background: #f7f7f8;
      color: #111827;
      font-family: "Inter", sans-serif;
    }

    .error-kicker {
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #6B46C1;
      margin-bottom: 1rem;
    }

    .error-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(2.8rem, 6vw, 5rem);
      line-height: 0.94;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #111827;
      margin-bottom: 1.1rem;
    }

    .error-text {
      font-size: 1.05rem;
      line-height: 1.85;
      color: #64748b;
    }

    @media (max-width: 767px) {
      .error-title {
        font-size: clamp(2.3rem, 10vw, 3.4rem);
      }

      .error-text {
        font-size: 1rem;
        line-height: 1.75;
      }
    }
  </style>
</head>
<body class="error-page">
  <%- include("partials/header") %>

  <section class="py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-6 md:px-16 text-center">
      <div class="bg-white border border-gray-100 rounded-[30px] shadow-sm p-10 md:p-14">
        <p class="error-kicker">Server Error</p>

        <h1 class="error-title">
          Something went wrong
        </h1>

        <p class="error-text mb-8">
          <%= typeof message !== 'undefined' && message ? message : "We hit an unexpected issue while loading this page. Please try again in a moment." %>
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/" class="inline-flex items-center justify-center rounded-2xl bg-[#6B46C1] text-white px-6 py-3 font-semibold hover:bg-purple-700 transition">
            Return Home
          </a>
          <button onclick="window.location.reload()" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-6 py-3 font-semibold text-gray-800 hover:border-[#6B46C1] hover:text-[#6B46C1] transition">
            Try Again
          </button>
        </div>
      </div>
    </div>
  </section>

  <%- include("partials/footer") %>
</body>
</html>