<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= academy.name %> Courses</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("../partials/header") %>

  <section class="bg-gradient-to-r from-[#4F46E5] via-[#7C3AED] to-[#C026D3] text-white">
    <div class="max-w-7xl mx-auto px-6 md:px-16 py-10 md:py-12">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
        <div>
          <p class="text-white/80 text-sm md:text-base mb-3">
            <a href="/academy" class="hover:text-white transition">Academy</a>
            <span class="mx-2">/</span>
            <span class="font-semibold"><%= academy.name %></span>
          </p>
          <h1 class="text-3xl md:text-5xl font-extrabold mb-3"><%= academy.name %></h1>
          <p class="text-lg md:text-2xl text-white/90">
            <%= academy.shortDescription || "Your online learning platform." %>
          </p>
        </div>

        <% if (!isLoggedIn) { %>
          <a
            href="#"
            class="open-auth-modal inline-flex items-center justify-center rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition self-start lg:self-auto"
            data-modal-mode="login"
            data-redirect-after-auth="/academy/<%= academy.slug %>/courses"
          >
            Sign In / Register
          </a>
        <% } else { %>
          <a
            href="/academy/<%= academy.slug %>/documents"
            class="inline-flex items-center justify-center rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition self-start lg:self-auto"
          >
            My Documents
          </a>
        <% } %>
      </div>
    </div>

    <div class="border-t border-white/15">
      <div class="max-w-7xl mx-auto px-6 md:px-16">
        <div class="flex items-center gap-8 overflow-x-auto">
          <a href="/academy/<%= academy.slug %>/courses" class="inline-flex h-14 items-center border-b-2 border-white text-white font-semibold whitespace-nowrap">
            <span class="mr-2">📖</span>
            Courses
          </a>
          <a href="/academy/<%= academy.slug %>/documents" class="inline-flex h-14 items-center border-b-2 border-transparent text-white/70 font-medium whitespace-nowrap hover:text-white transition">
            <span class="mr-2">📄</span>
            Documents
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-12 md:pt-14 pb-10">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-950 mb-4">
        Available Courses
      </h2>
      <p class="text-lg md:text-2xl text-slate-600 max-w-4xl">
        Explore the courses available in <%= academy.name %> and unlock each level to access its grouped courses, documents, audios, and assignments.
      </p>
    </div>
  </section>

  <section class="pb-16 md:pb-20">
    <div class="max-w-7xl mx-auto px-6 md:px-16">

      <% if (payment === "pending") { %>
        <div class="mb-8 rounded-2xl border border-blue-200 bg-blue-50 px-5 py-4 text-blue-700 font-medium">
          Your payment request has been submitted and is awaiting admin verification.
        </div>
      <% } %>

      <% if (payment === "already-unlocked") { %>
        <div class="mb-8 rounded-2xl border border-green-200 bg-green-50 px-5 py-4 text-green-700 font-medium">
          You already have access to this level.
        </div>
      <% } %>

      <% if (!groupedLevels || !groupedLevels.length) { %>
        <div class="rounded-[26px] border border-gray-200 bg-white p-10 text-center shadow-sm">
          <h3 class="text-2xl md:text-3xl font-extrabold text-gray-950 mb-3">
            No course levels available yet
          </h3>
          <p class="text-lg text-slate-600">
            Published levels and courses will appear here automatically.
          </p>
        </div>
      <% } else { %>
        <div class="space-y-12">
          <% groupedLevels.forEach((level) => { %>
            <section class="space-y-6">
              <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div>
                  <h3 class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-2">
                    <%= level.title %>
                  </h3>
                  <p class="text-lg text-slate-600">
                    <%= level.description || "Grouped courses for this level." %>
                  </p>
                </div>

                <div class="flex flex-wrap items-center gap-3">
                  <% if (level.price) { %>
                    <span class="inline-flex rounded-full bg-purple-100 text-purple-700 px-4 py-2 text-sm font-semibold">
                      <%= level.price %>
                    </span>
                  <% } %>

                  <% if (level.isUnlocked) { %>
                    <span class="inline-flex rounded-full bg-green-100 text-green-700 px-4 py-2 text-sm font-semibold">
                      Unlocked
                    </span>
                  <% } else if (level.hasPendingRequest) { %>
                    <span class="inline-flex rounded-full bg-blue-100 text-blue-700 px-4 py-2 text-sm font-semibold">
                      Pending Verification
                    </span>
                  <% } else { %>
                    <span class="inline-flex rounded-full bg-yellow-100 text-yellow-700 px-4 py-2 text-sm font-semibold">
                      Locked
                    </span>
                  <% } %>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                <% level.courses.forEach((course) => { %>
                  <article class="bg-white border border-indigo-100 rounded-[26px] shadow-sm overflow-hidden <%= !level.isUnlocked ? 'opacity-95' : '' %>">
                    <div class="relative h-56 overflow-hidden">
                      <img
                        src="<%= course.image || '/images/event1.jpg' %>"
                        alt="<%= course.title %>"
                        class="w-full h-full object-cover <%= !level.isUnlocked ? 'grayscale-[20%]' : '' %>"
                      />

                      <% if (!level.isUnlocked) { %>
                        <div class="absolute top-4 left-4">
                          <span class="inline-flex rounded-full bg-white/95 text-gray-900 px-4 py-2 text-sm font-semibold shadow">
                            🔒 Locked Level
                          </span>
                        </div>
                      <% } %>
                    </div>

                    <div class="p-6 md:p-7">
                      <h3 class="text-2xl font-extrabold text-gray-950 mb-4 leading-snug">
                        <%= course.title %>
                      </h3>

                      <p class="text-lg leading-relaxed text-slate-700 mb-5 line-clamp-3">
                        <%= course.description %>
                      </p>

                      <div class="flex flex-wrap items-center gap-5 text-base text-slate-600 mb-5">
                        <span class="inline-flex items-center gap-2">
                          <span>🕒</span>
                          <%= course.duration || "Not specified" %>
                        </span>

                        <span class="inline-flex items-center gap-2">
                          <span>▶</span>
                          <%= course.lessons || "Not specified" %>
                        </span>
                      </div>

                      <% if (!level.isUnlocked) { %>
                        <div class="mb-5 rounded-2xl bg-gray-50 border border-gray-200 px-4 py-4">
                          <p class="text-sm text-slate-600">
                            Pay for <span class="font-semibold text-gray-900"><%= level.title %></span> to unlock all courses in this level.
                          </p>
                        </div>
                      <% } %>

                      <% if (level.isUnlocked) { %>
                        <a
                          href="/academy/<%= academy.slug %>/courses/<%= course.slug %>"
                          class="w-full inline-flex items-center justify-center rounded-2xl text-white px-6 py-4 text-lg font-semibold transition <%= course.buttonClass || 'bg-[#4F46E5] hover:bg-indigo-700' %>"
                        >
                          <%= course.buttonText || "View Course" %>
                        </a>
                      <% } else { %>
                        <% if (level.hasPendingRequest) { %>
                          <button
                            type="button"
                            class="w-full inline-flex items-center justify-center rounded-2xl bg-yellow-500 text-white px-6 py-4 text-lg font-semibold cursor-not-allowed"
                            disabled
                          >
                            Pending Verification
                          </button>
                        <% } else if (isLoggedIn) { %>
                          <a
                            href="/academy/<%= academy.slug %>/manual-payment/levels/<%= level._id %>"
                            class="w-full inline-flex items-center justify-center rounded-2xl bg-[#6B46C1] text-white px-6 py-4 text-lg font-semibold hover:bg-purple-700 transition"
                          >
                            Pay Manually
                          </a>
                        <% } else { %>
                          <a
                            href="#"
                            class="open-auth-modal w-full inline-flex items-center justify-center rounded-2xl bg-[#6B46C1] text-white px-6 py-4 text-lg font-semibold hover:bg-purple-700 transition"
                            data-modal-mode="login"
                            data-redirect-after-auth="/academy/<%= academy.slug %>/courses"
                          >
                            Sign In / Register
                          </a>
                        <% } %>
                      <% } %>
                    </div>
                  </article>
                <% }) %>
              </div>
            </section>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section class="pb-20 md:pb-24">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[28px] border border-indigo-100 bg-indigo-50/70 p-8 md:p-10">
        <h3 class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-4">
          Need Help Choosing a Course?
        </h3>
        <p class="text-lg md:text-[1.15rem] text-slate-700 leading-relaxed mb-6">
          Contact our academic advisor for guidance on the right starting level in <%= academy.name %>.
        </p>

        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-2xl bg-[#4F46E5] text-white px-8 py-4 text-lg font-semibold hover:bg-indigo-700 transition shadow-sm"
        >
          Contact Advisor
        </a>
      </div>
    </div>
  </section>

  <%- include("../partials/footer") %>
  <%- include("../partials/auth-modal") %>
  <script src="/js/auth-modal.js"></script>

</body>
</html>