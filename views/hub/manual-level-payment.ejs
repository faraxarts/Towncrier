<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manual Payment | <%= academy.name %></title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("../partials/header") %>

  <section class="py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-6 md:px-10">
      <div class="mb-8">
        <a href="/academy/<%= academy.slug %>/courses" class="text-[#6B46C1] font-semibold hover:underline">
          ← Back to <%= academy.name %> Courses
        </a>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-5 gap-8">

        <div class="xl:col-span-2 bg-white border border-gray-100 rounded-[28px] shadow-sm p-8">
          <h1 class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-4">
            Manual Payment
          </h1>

          <p class="text-lg text-slate-700 mb-6">
            Complete payment for <strong><%= level.title %></strong> in <strong><%= academy.name %></strong> using the bank details below.
          </p>

          <div class="space-y-4 text-base md:text-lg text-slate-700">
            <p><strong>Bank Name:</strong> <%= bankName %></p>
            <p><strong>Account Name:</strong> <%= accountName %></p>
            <p><strong>Account Number:</strong> <%= accountNumber %></p>
            <p><strong>Display Price:</strong> <%= level.price || "Not set" %></p>
            <p><strong>Transfer Amount (Naira):</strong> <%= level.priceNaira ? `₦${Number(level.priceNaira).toLocaleString()}` : "Not set" %></p>
          </div>

          <div class="mt-8 rounded-2xl bg-purple-50 border border-purple-100 p-5">
            <p class="text-sm font-semibold text-slate-600 mb-2">USE THIS REFERENCE</p>
            <p class="text-xl md:text-2xl font-extrabold text-[#6B46C1] break-all">
              <%= paymentRequest.reference %>
            </p>
          </div>
        </div>

        <div class="xl:col-span-3 bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
          <h2 class="text-2xl md:text-3xl font-extrabold text-gray-950 mb-4">
            I Have Paid
          </h2>

          <p class="text-lg text-slate-600 mb-8">
            After making the transfer, submit the details below for admin verification.
          </p>

          <form action="/academy/<%= academy.slug %>/manual-payment/levels/<%= level._id %>/submit" method="POST" enctype="multipart/form-data" class="space-y-6">
            <input type="hidden" name="requestId" value="<%= paymentRequest._id %>">

            <div>
              <label class="block text-sm font-semibold mb-2">Payer Name</label>
              <input name="payerName" type="text" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5" required>
            </div>

            <div class="grid grid-cols-1 gap-6">
              <div>
                <label class="block text-sm font-semibold mb-2">Bank Transaction Reference / Session ID</label>
                <input
                  name="transactionNumber"
                  type="text"
                  class="w-full rounded-2xl border border-gray-200 px-4 py-3.5"
                  placeholder="Enter the transfer reference from your bank app or alert"
                  required
                >
                <p class="mt-2 text-sm text-slate-500">
                  This is the transaction reference, session ID, or transfer code from your bank transaction.
                </p>
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold mb-2">Short Note</label>
              <textarea name="note" rows="4" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5"></textarea>
            </div>

            <div>
              <label class="block text-sm font-semibold mb-2">Upload Proof (Optional)</label>
              <input name="proofFile" type="file" accept=".jpg,.jpeg,.png,.pdf" class="w-full rounded-2xl border border-gray-200 px-4 py-3.5">
            </div>

            <button type="submit" class="rounded-2xl bg-[#6B46C1] text-white px-8 py-4 font-semibold hover:bg-purple-700 transition">
              Submit Payment Request
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <%- include("../partials/footer") %>
</body>
</html>