<%
  const isConnectActive = ["/events", "/contact"].includes(currentPath);
  const isMinistriesActive = ["/ministries/dbw", "/ministries/bootcamp", "/ministries/arrows"].includes(currentPath);
  const isLeadActive = ["/livingstone-akinadewo", "/ministry-lead"].includes(currentPath);
  const isAboutActive = currentPath === "/about";
  const isHomeActive = currentPath === "/";
  const isAcademyActive =
    currentPath === "/academy" ||
    currentPath.startsWith("/academy/");
%>

<style>
  :root {
  --tcem-header-purple: #6b46c1;
}

.site-header {
  background: var(--tcem-header-purple);
  border-bottom: 1px solid rgba(255, 255, 255, 0.14);
  box-shadow: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}

  .site-header__brand-name {
    color: #ffffff;
  }

  .site-header__brand-tag {
    color: rgba(255, 255, 255, 0.82);
  }

  .site-header__nav-link,
  .site-header__nav-button {
    position: relative;
    color: #ffffff;
    transition: color 180ms ease;
  }

  .site-header__nav-link::after,
  .site-header__nav-button::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.28rem;
    width: 100%;
    height: 2px;
    background: #ffffff;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 260ms ease;
    border-radius: 999px;
  }

  .site-header__nav-link:hover::after,
  .site-header__nav-button:hover::after,
  .site-header__nav-link.is-active::after,
  .site-header__nav-button.is-active::after {
    transform: scaleX(1);
  }

  .site-header__nav-link:hover,
  .site-header__nav-button:hover,
  .site-header__nav-link.is-active,
  .site-header__nav-button.is-active {
    color: #ffffff;
  }

  .site-header__academy-btn {
    border: 1.5px solid rgba(255, 255, 255, 0.75);
    color: #ffffff;
    background: transparent;
    box-shadow: none;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .site-header__academy-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #ffffff;
    color: #ffffff;
  }

  .site-header__icon-btn {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
  }

  .site-header__icon-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.55);
    color: #ffffff;
  }

  .site-header__logout-btn {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
  }

  .site-header__logout-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.55);
    color: #ffffff;
  }

  .site-header__mobile-toggle {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
  }

  .site-header__mobile-toggle:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .site-header__mobile-panel {
  background: var(--tcem-header-purple);
  border-top: 1px solid rgba(255, 255, 255, 0.12);
}

  .site-header__mobile-link {
    color: #ffffff;
    background: transparent;
    border: 1px solid transparent;
  }

  .site-header__mobile-link:hover,
  .site-header__mobile-link.is-active {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.12);
  }

  .site-header__mobile-details {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.03);
  }

  .site-header__mobile-summary {
    color: #ffffff;
  }

  .site-header__mobile-summary:hover,
  .site-header__mobile-summary.is-active {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }

  .site-header__mobile-submenu {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .site-header__mobile-submenu a {
    color: rgba(255, 255, 255, 0.9);
  }

  .site-header__mobile-submenu a:hover,
  .site-header__mobile-submenu a.is-active {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }

  .site-header__dropdown-card {
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.08);
  }

  .site-header__dropdown-card a {
    color: #374151;
  }

  .site-header__dropdown-card a:hover {
    background: rgba(107, 70, 193, 0.08);
    color: #6b46c1;
  }

  @media (max-width: 767px) {
    .site-header__brand-name {
      font-size: 12px;
      line-height: 1.13;
    }

    .site-header__brand-tag {
      font-size: 9px;
      line-height: 1.1;
    }
  }
</style>

<header class="site-header sticky top-0 z-50 w-full overflow-x-hidden">
  <div class="max-w-7xl mx-auto h-20 px-4 sm:px-5 md:px-6 lg:px-8 flex items-center justify-between gap-3 lg:gap-8">

    <!-- Logo / Ministry Name -->
    <a href="/" class="min-w-0 flex items-center gap-3 overflow-hidden flex-1 lg:flex-none lg:min-w-[360px] xl:min-w-[430px]">
      <div class="bg-white/10 h-10 w-10 sm:h-11 sm:w-11 flex items-center justify-center rounded-xl shadow-md overflow-hidden border border-white/20 shrink-0">
        <img
          src="/images/tcem-logo.png"
          alt="Town Crier Evangelical Ministries Logo"
          class="h-full w-full object-contain"
        />
      </div>

      <div class="min-w-0 flex-1 leading-tight overflow-hidden">
        <p class="site-header__brand-name font-extrabold text-[10px] sm:text-[11px] md:text-xs lg:text-sm xl:text-base leading-[1.12] break-words max-w-full">
          TOWN CRIER EVANGELICAL MINISTRIES
        </p>
        <p class="site-header__brand-tag house-of-bread text-[9px] sm:text-[10px] md:text-[11px] lg:text-xs break-words mt-0.5">
          THE HOUSE OF BREAD
        </p>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex flex-1 items-center justify-center gap-5 xl:gap-7 min-w-0">
      <a
        href="/"
        class="site-header__nav-link inline-flex items-center px-1 py-2 text-sm xl:text-base font-medium whitespace-nowrap <%= isHomeActive ? 'is-active' : '' %>"
      >
        Home
      </a>

      <a
        href="/about"
        class="site-header__nav-link inline-flex items-center px-1 py-2 text-sm xl:text-base font-medium whitespace-nowrap <%= isAboutActive ? 'is-active' : '' %>"
      >
        About
      </a>

      <a
        href="/livingstone-akinadewo"
        class="site-header__nav-link inline-flex items-center px-1 py-2 text-sm xl:text-base font-medium whitespace-nowrap <%= isLeadActive ? 'is-active' : '' %>"
      >
        Livingstone Akinadewo
      </a>

      <div class="relative group">
        <button
          type="button"
          class="site-header__nav-button inline-flex items-center gap-1 px-1 py-2 text-sm xl:text-base font-medium whitespace-nowrap <%= isConnectActive ? 'is-active' : '' %>"
        >
          Connect
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div class="absolute left-0 top-full pt-3 w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="site-header__dropdown-card rounded-2xl shadow-xl overflow-hidden">
            <a href="/events" class="block px-4 py-3">
              Events
            </a>
            <a href="/contact" class="block px-4 py-3 border-t border-gray-100">
              Contact
            </a>
          </div>
        </div>
      </div>

      <div class="relative group">
        <button
          type="button"
          class="site-header__nav-button inline-flex items-center gap-1 px-1 py-2 text-sm xl:text-base font-medium whitespace-nowrap <%= isMinistriesActive ? 'is-active' : '' %>"
        >
          Ministries
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div class="absolute left-0 top-full pt-3 w-72 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="site-header__dropdown-card rounded-2xl shadow-xl overflow-hidden">
            <a href="/ministries/dbw" class="block px-4 py-3">
              Discipleship by the Word
            </a>
            <a href="/ministries/bootcamp" class="block px-4 py-3 border-t border-gray-100">
              Discipleship Bootcamp
            </a>
            <a href="/ministries/arrows" class="block px-4 py-3 border-t border-gray-100">
              Arrows in the Quiver
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Desktop Right -->
    <div class="hidden lg:flex items-center gap-3 xl:gap-4 shrink-0">
      <a
        href="/academy"
        class="site-header__academy-btn rounded-full px-5 xl:px-6 py-3 text-sm xl:text-base font-bold whitespace-nowrap <%= isAcademyActive ? 'bg-white/10' : '' %>"
      >
        Academy
      </a>

      <% if (isLoggedIn && isAdmin) { %>
        <a
          href="/admin"
          class="site-header__academy-btn rounded-full px-5 xl:px-6 py-3 text-sm xl:text-base font-bold whitespace-nowrap"
        >
          Admin
        </a>
      <% } %>

      <% if (isLoggedIn) { %>
        <a
          href="/notifications"
          class="site-header__icon-btn relative inline-flex items-center justify-center h-12 w-12 rounded-full border transition"
          aria-label="Notifications"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0m6 0H9" />
          </svg>

          <% if (unreadNotificationCount > 0) { %>
            <span class="absolute -top-1 -right-1 min-w-[22px] h-[22px] px-1 inline-flex items-center justify-center rounded-full bg-red-500 text-white text-xs font-bold">
              <%= unreadNotificationCount > 99 ? "99+" : unreadNotificationCount %>
            </span>
          <% } %>
        </a>

        <button
          type="button"
          id="desktop-logout-btn"
          class="site-header__logout-btn rounded-full border px-4 xl:px-5 py-3 text-sm xl:text-base font-semibold transition whitespace-nowrap"
        >
          Logout
        </button>
      <% } %>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-button"
      type="button"
      class="site-header__mobile-toggle lg:hidden inline-flex items-center justify-center w-10 h-10 sm:w-11 sm:h-11 rounded-xl transition shrink-0"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="menu-open-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>

      <svg id="menu-close-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile / Tablet Menu -->
  <div id="mobile-menu" class="site-header__mobile-panel hidden lg:hidden shadow-lg">
    <div class="px-4 py-4 space-y-2">
      <a
        href="/"
        class="site-header__mobile-link block rounded-xl px-4 py-3 font-medium <%= isHomeActive ? 'is-active' : '' %>"
      >
        Home
      </a>

      <a
        href="/about"
        class="site-header__mobile-link block rounded-xl px-4 py-3 font-medium <%= isAboutActive ? 'is-active' : '' %>"
      >
        About
      </a>

      <a
        href="/livingstone-akinadewo"
        class="site-header__mobile-link block rounded-xl px-4 py-3 font-medium <%= isLeadActive ? 'is-active' : '' %>"
      >
        Livingstone Akinadewo
      </a>

      <details class="site-header__mobile-details group rounded-xl overflow-hidden" <%= isConnectActive ? 'open' : '' %>>
        <summary class="site-header__mobile-summary list-none cursor-pointer px-4 py-3 flex items-center justify-between font-medium <%= isConnectActive ? 'is-active' : '' %>">
          <span>Connect</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>

        <div class="site-header__mobile-submenu">
          <a
            href="/events"
            class="block px-6 py-3 <%= currentPath === '/events' ? 'is-active' : '' %>"
          >
            Events
          </a>
          <a
            href="/contact"
            class="block px-6 py-3 border-t border-white/10 <%= currentPath === '/contact' ? 'is-active' : '' %>"
          >
            Contact
          </a>
        </div>
      </details>

      <details class="site-header__mobile-details group rounded-xl overflow-hidden" <%= isMinistriesActive ? 'open' : '' %>>
        <summary class="site-header__mobile-summary list-none cursor-pointer px-4 py-3 flex items-center justify-between font-medium <%= isMinistriesActive ? 'is-active' : '' %>">
          <span>Ministries</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>

        <div class="site-header__mobile-submenu">
          <a
            href="/ministries/dbw"
            class="block px-6 py-3 <%= currentPath === '/ministries/dbw' ? 'is-active' : '' %>"
          >
            Discipleship by the Word
          </a>
          <a
            href="/ministries/bootcamp"
            class="block px-6 py-3 border-t border-white/10 <%= currentPath === '/ministries/bootcamp' ? 'is-active' : '' %>"
          >
            Discipleship Bootcamp
          </a>
          <a
            href="/ministries/arrows"
            class="block px-6 py-3 border-t border-white/10 <%= currentPath === '/ministries/arrows' ? 'is-active' : '' %>"
          >
            Arrows in the Quiver
          </a>
        </div>
      </details>

      <a
        href="/academy"
        class="site-header__academy-btn mt-3 inline-flex w-full items-center justify-center rounded-full px-6 py-3 font-bold <%= isAcademyActive ? 'bg-white/10' : '' %>"
      >
        Academy
      </a>

      <% if (isLoggedIn && isAdmin) { %>
        <a
          href="/admin"
          class="site-header__academy-btn inline-flex w-full items-center justify-center rounded-full px-6 py-3 font-bold"
        >
          Admin
        </a>
      <% } %>

      <% if (isLoggedIn) { %>
        <a
          href="/notifications"
          class="site-header__mobile-link inline-flex w-full items-center justify-between rounded-full px-6 py-3 font-bold"
        >
          <span>Notifications</span>

          <% if (unreadNotificationCount > 0) { %>
            <span class="min-w-[24px] h-[24px] px-1 inline-flex items-center justify-center rounded-full bg-red-500 text-white text-xs font-bold">
              <%= unreadNotificationCount > 99 ? "99+" : unreadNotificationCount %>
            </span>
          <% } %>
        </a>

        <button
          type="button"
          id="mobile-logout-btn"
          class="site-header__mobile-link inline-flex w-full items-center justify-center rounded-full px-6 py-3 font-bold"
        >
          Logout
        </button>
      <% } %>
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");
    const openIcon = document.getElementById("menu-open-icon");
    const closeIcon = document.getElementById("menu-close-icon");

    const desktopLogoutBtn = document.getElementById("desktop-logout-btn");
    const mobileLogoutBtn = document.getElementById("mobile-logout-btn");

    function openMenu() {
      if (!menu || !openIcon || !closeIcon || !button) return;
      menu.classList.remove("hidden");
      openIcon.classList.add("hidden");
      closeIcon.classList.remove("hidden");
      button.setAttribute("aria-expanded", "true");
    }

    function closeMenu() {
      if (!menu || !openIcon || !closeIcon || !button) return;
      menu.classList.add("hidden");
      openIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      button.setAttribute("aria-expanded", "false");
    }

    if (button && menu && openIcon && closeIcon) {
      button.addEventListener("click", function () {
        if (menu.classList.contains("hidden")) {
          openMenu();
        } else {
          closeMenu();
        }
      });

      document.addEventListener("click", function (event) {
        const clickedInsideMenu = menu.contains(event.target);
        const clickedButton = button.contains(event.target);

        if (!menu.classList.contains("hidden") && !clickedInsideMenu && !clickedButton) {
          closeMenu();
        }
      });

      window.addEventListener("resize", function () {
        if (window.innerWidth >= 1024) {
          closeMenu();
        }
      });
    }

    async function handleLogout() {
      try {
        const response = await fetch("/auth/logout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
        });

        const data = await response.json();

        if (!response.ok) {
          alert(data.message || "Logout failed.");
          return;
        }

        window.location.href = "/";
      } catch (error) {
        console.error("Logout error:", error);
        alert("Something went wrong while logging out.");
      }
    }

    if (desktopLogoutBtn) {
      desktopLogoutBtn.addEventListener("click", handleLogout);
    }

    if (mobileLogoutBtn) {
      mobileLogoutBtn.addEventListener("click", handleLogout);
    }
  });
</script>