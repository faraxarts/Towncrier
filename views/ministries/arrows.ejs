<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Arrows in the Quiver | Town Crier</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("../partials/header") %>

  <!-- MINISTRIES SUB NAV -->
  <section class="border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="flex items-center gap-8 overflow-x-auto">
        <a href="/ministries/dbw" class="inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#4F46E5] whitespace-nowrap transition">
          Discipleship by the Word
        </a>
        <a href="/ministries/bootcamp" class="inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#4F46E5] whitespace-nowrap transition">
          Discipleship Bootcamp
        </a>
        <a href="/ministries/arrows" class="inline-flex h-14 items-center border-b-2 border-[#4F46E5] text-[#4F46E5] font-semibold whitespace-nowrap">
          Arrows in the Quiver
        </a>
      </div>
    </div>
  </section>

  <!-- HERO -->
  <section class="py-12 md:py-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-gradient-to-r from-[#08C443] to-[#14B8A6] px-8 md:px-12 py-12 md:py-16 text-white shadow-sm">
        <div class="max-w-4xl">
          <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-5">
            Arrows in the Quiver
          </h1>

          <p class="text-xl md:text-3xl font-semibold text-white/95 mb-6">
            Children &amp; Youth Ministry
          </p>

          <p class="text-lg md:text-2xl leading-relaxed text-white/95 mb-6">
            Arrows in the Quiver is a youth-focused outreach and discipleship initiative of Town Crier Evangelical Ministries, created to rescue and raise teenagers as godly, purposeful, and well-formed vessels for Christ. The project reflects the biblical picture of children and young people as “arrows” in God’s hand, prepared, sharpened, and released for divine purpose.
          </p>

          <p class="text-lg md:text-2xl leading-relaxed text-white/95"> "Like arrows in the hands of a warrior, so are children born in one's youth" - Psalm 127:4</p>
            
        </div>
      </div>
    </div>
  </section>

  <!-- VISION + MISSION -->
  <section class="pb-12 md:pb-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
          <div class="w-14 h-14 rounded-2xl bg-green-100 flex items-center justify-center mb-7">
            <span class="text-2xl">🎯</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-5">
            Our Vision
          </h2>

          <p class="text-lg md:text-[1.2rem] leading-relaxed text-slate-700">
            To raise a generation of children and youth who love God passionately, know His Word deeply, live with purpose, and impact their world for Christ.
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
          <div class="w-14 h-14 rounded-2xl bg-emerald-100 flex items-center justify-center mb-7">
            <span class="text-2xl">💚</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-5">
            Our Mission
          </h2>

          <p class="text-lg md:text-[1.2rem] leading-relaxed text-slate-700">
            To partner with parents in nurturing children and teens spiritually, providing biblical education, character development, and opportunities for ministry involvement.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- AGE GROUPS -->
  <section class="py-8 md:py-10">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-950">
          Age Groups &amp; Programs
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">

        <div class="rounded-[28px] border border-yellow-200 bg-yellow-50/70 p-8 md:p-10 shadow-sm">
          <div class="text-5xl mb-6 text-center">🌱</div>
          <h3 class="text-3xl font-extrabold text-gray-950 text-center mb-2">Little Arrows</h3>
          <p class="text-center text-xl text-slate-600 mb-8">Ages 3-6</p>

          <ul class="space-y-4 text-lg text-slate-700">
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Bible Stories</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Songs &amp; Rhymes</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Creative Play</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Character Building</li>
          </ul>
        </div>

        <div class="rounded-[28px] border border-indigo-200 bg-indigo-50/70 p-8 md:p-10 shadow-sm">
          <div class="text-5xl mb-6 text-center">⭐</div>
          <h3 class="text-3xl font-extrabold text-gray-950 text-center mb-2">Junior Arrows</h3>
          <p class="text-center text-xl text-slate-600 mb-8">Ages 7-12</p>

          <ul class="space-y-4 text-lg text-slate-700">
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Bible Study</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Memory Verses</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Games &amp; Activities</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Ministry Skills</li>
          </ul>
        </div>

        <div class="rounded-[28px] border border-emerald-200 bg-emerald-50/70 p-8 md:p-10 shadow-sm">
          <div class="text-5xl mb-6 text-center">🎯</div>
          <h3 class="text-3xl font-extrabold text-gray-950 text-center mb-2">Teen Arrows</h3>
          <p class="text-center text-xl text-slate-600 mb-8">Ages 13-17</p>

          <ul class="space-y-4 text-lg text-slate-700">
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Deep Bible Study</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Leadership Training</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Mentorship</li>
            <li class="flex items-start gap-3"><span class="text-green-600 mt-1">•</span> Evangelism</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- WEEKLY ACTIVITIES -->
  <section class="pt-12 md:pt-14 pb-8">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="text-center mb-10">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-950">
          Weekly Activities
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-7 md:p-8">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-2xl bg-purple-100 flex items-center justify-center text-2xl shrink-0">
              📖
            </div>
            <div>
              <h3 class="text-2xl font-extrabold text-gray-950 mb-1">Sunday Children's Church</h3>
              <p class="text-lg text-slate-600 mb-4">Every Sunday, 9:00 AM</p>
              <p class="text-lg leading-relaxed text-slate-700">
                Age-appropriate Bible teaching, worship, and activities during main service
              </p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-7 md:p-8">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-2xl bg-green-100 flex items-center justify-center text-2xl shrink-0">
              👥
            </div>
            <div>
              <h3 class="text-2xl font-extrabold text-gray-950 mb-1">Friday Teen Fellowship</h3>
              <p class="text-lg text-slate-600 mb-4">Every Friday, 5:00 PM</p>
              <p class="text-lg leading-relaxed text-slate-700">
                Worship, Bible study, games, and fellowship specifically for teenagers
              </p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-7 md:p-8">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-2xl bg-blue-100 flex items-center justify-center text-2xl shrink-0">
              🎵
            </div>
            <div>
              <h3 class="text-2xl font-extrabold text-gray-950 mb-1">Saturday Kids' Club</h3>
              <p class="text-lg text-slate-600 mb-4">Every Saturday, 10:00 AM</p>
              <p class="text-lg leading-relaxed text-slate-700">
                Fun activities, life skills, crafts, and biblical values for ages 7-12
              </p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-7 md:p-8">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-2xl bg-orange-100 flex items-center justify-center text-2xl shrink-0">
              🧡
            </div>
            <div>
              <h3 class="text-2xl font-extrabold text-gray-950 mb-1">Monthly Parents' Forum</h3>
              <p class="text-lg text-slate-600 mb-4">Last Saturday, 2:00 PM</p>
              <p class="text-lg leading-relaxed text-slate-700">
                Parenting workshops, prayer, and partnership meetings for parents
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SPECIAL PROGRAMS -->
  <section class="py-12 md:py-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] border border-emerald-100 bg-emerald-50/60 p-8 md:p-10">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-950 mb-8">
          Special Programs &amp; Events
        </h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="bg-white rounded-[22px] p-6 shadow-sm">
            <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Summer Camp</h3>
            <p class="text-lg text-slate-700 leading-relaxed">
              Week-long outdoor adventure with biblical teaching and team building
            </p>
          </div>

          <div class="bg-white rounded-[22px] p-6 shadow-sm">
            <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Teen Leadership Academy</h3>
            <p class="text-lg text-slate-700 leading-relaxed">
              Quarterly training for young leaders ages 14-17
            </p>
          </div>

          <div class="bg-white rounded-[22px] p-6 shadow-sm">
            <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Children's Crusade</h3>
            <p class="text-lg text-slate-700 leading-relaxed">
              Annual outreach program where kids minister to other kids
            </p>
          </div>

          <div class="bg-white rounded-[22px] p-6 shadow-sm">
            <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Talent Discovery</h3>
            <p class="text-lg text-slate-700 leading-relaxed">
              Platform for children to discover and develop their God-given talents
            </p>
          </div>

          <div class="bg-white rounded-[22px] p-6 shadow-sm lg:col-span-1">
            <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Bible Quiz Competition</h3>
            <p class="text-lg text-slate-700 leading-relaxed">
              Quarterly competitions to encourage Scripture memorization
            </p>
          </div>

          <div class="bg-white rounded-[22px] p-6 shadow-sm lg:col-span-1">
            <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Service Projects</h3>
            <p class="text-lg text-slate-700 leading-relaxed">
              Community service opportunities teaching compassion and giving
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pt-4 pb-20 md:pb-24">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-[#08C443] px-8 md:px-12 py-12 md:py-14 text-white text-center shadow-sm">
        <h2 class="text-4xl md:text-5xl font-extrabold mb-5">
          Get Involved
        </h2>

        <p class="max-w-4xl mx-auto text-lg md:text-2xl leading-relaxed text-white/95 mb-8">
          Partner with us in raising godly children. Whether you're a parent, volunteer, or supporter, there's a place for you!
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
              href="/contact?type=registration&target=Arrows%20in%20the%20Quiver#contact-form-section"
              class="inline-flex items-center justify-center gap-3 rounded-2xl bg-white text-[#08A53B] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition min-w-[190px]"
          >
              Join Our Team
                  <span class="text-2xl leading-none">→</span>
          </a>

          <a
            href="/events"
            class="inline-flex items-center justify-center gap-3 rounded-2xl border border-white/20 bg-white/10 text-white px-8 py-4 text-lg font-semibold hover:bg-white/15 transition min-w-[230px]"
          >
            View Upcoming Events
            <span class="text-2xl leading-none">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

 <%- include("../partials/auth-modal") %>
<script src="/js/auth-modal.js"></script>

</body>
</html>