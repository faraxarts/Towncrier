<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Discipleship by the Word | Town Crier</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("../partials/header") %>

  <!-- MINISTRIES SUB NAV -->
  <section class="border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="flex items-center gap-8 overflow-x-auto">
        <a href="/ministries/dbw" class="inline-flex h-14 items-center border-b-2 border-[#4F46E5] text-[#4F46E5] font-semibold whitespace-nowrap">
          Discipleship by the Word
        </a>
        <a href="/ministries/bootcamp" class="inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#4F46E5] whitespace-nowrap transition">
          Discipleship Bootcamp
        </a>
        <a href="/ministries/arrows" class="inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#4F46E5] whitespace-nowrap transition">
          Arrows in the Quiver
        </a>
      </div>
    </div>
  </section>

  <!-- HERO -->
  <section class="py-12 md:py-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-gradient-to-r from-[#4F46E5] via-[#9333EA] to-[#EC4899] px-8 md:px-12 py-12 md:py-16 text-white shadow-sm">
        <div class="max-w-4xl">
          <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-5">
            Discipleship by the Word
          </h1>
          <p class="text-lg md:text-2xl leading-relaxed text-white/95 mb-8">
           Discipleship by the Word [DBW] is a structured discipleship ministry under Town Crier Evangelical Ministries [TCEM], established by Livingstone Favour Akinadewo in September 2022. Its purpose is to raise and form believers through biblical study, prayer, reflection, assignments, cell-group discipleship, and practical evangelistic work.
          </p>

          <a
             href="/contact?type=registration&target=Discipleship%20by%20the%20Word#contact-form-section"
            class="inline-flex items-center gap-3 rounded-2xl bg-white text-[#4F46E5] px-7 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition"
          >
            Join our Discipleship group
            <span class="text-2xl leading-none">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION + APPROACH -->
  <section class="pb-12 md:pb-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
          <div class="w-14 h-14 rounded-2xl bg-indigo-100 flex items-center justify-center mb-7">
            <span class="text-2xl">🎯</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-5">
            Our Mission
          </h2>

          <p class="text-lg md:text-[1.2rem] leading-relaxed text-slate-700">
            To raise up biblically grounded disciples who understand God's Word, live by its principles, and effectively minister to others. We focus on systematic Bible teaching, practical application, and spiritual formation.
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
          <div class="w-14 h-14 rounded-2xl bg-purple-100 flex items-center justify-center mb-7">
            <span class="text-2xl">📖</span>
          </div>

          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-5">
            Our Approach
          </h2>

          <p class="text-lg md:text-[1.2rem] leading-relaxed text-slate-700">
            We use a blend of classroom teaching, small group discussions, mentorship, and practical ministry assignments. Our curriculum covers biblical foundations, theology, spiritual disciplines, and ministry skills.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- PROGRAM FEATURES -->
  <section class="py-8 md:py-10">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-950">
          Program Features
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">

        <div class="bg-white border border-gray-100 rounded-[26px] shadow-sm p-7 md:p-8">
          <div class="text-4xl mb-6">📘</div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-4">Systematic Bible Study</h3>
          <p class="text-lg leading-relaxed text-slate-700">
            Comprehensive study through Old and New Testament books with emphasis on interpretation and application
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[26px] shadow-sm p-7 md:p-8">
          <div class="text-4xl mb-6">👥</div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-4">Mentorship Groups</h3>
          <p class="text-lg leading-relaxed text-slate-700">
            Small group accountability and discipleship with experienced leaders guiding your spiritual growth
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[26px] shadow-sm p-7 md:p-8">
          <div class="text-4xl mb-6">🎯</div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-4">Practical Ministry</h3>
          <p class="text-lg leading-relaxed text-slate-700">
            Hands-on ministry experience including evangelism, teaching, and community service projects
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[26px] shadow-sm p-7 md:p-8">
          <div class="text-4xl mb-6">📚</div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-4">Resource Library</h3>
          <p class="text-lg leading-relaxed text-slate-700">
            Access to books, study materials, video teachings, and online courses through DBW HUB
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[26px] shadow-sm p-7 md:p-8">
          <div class="text-4xl mb-6">🙏</div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-4">Spiritual Disciplines</h3>
          <p class="text-lg leading-relaxed text-slate-700">
            Training in prayer, fasting, meditation, Scripture memory, and other spiritual practices
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[26px] shadow-sm p-7 md:p-8">
          <div class="text-4xl mb-6">⭐</div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-4">Leadership Development</h3>
          <p class="text-lg leading-relaxed text-slate-700">
            Equipping to lead Bible studies, mentor others, and serve effectively in various ministries
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- LEARNING TRACKS -->
  <section class="pt-12 md:pt-14 pb-8">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="text-center mb-10">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-950">
          Learning Tracks
        </h2>
      </div>

      <div class="space-y-6">
        <div class="rounded-[26px] border border-indigo-200 bg-indigo-50/70 p-6 md:p-8">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
            <div>
              <h3 class="text-2xl md:text-3xl font-extrabold text-gray-950 mb-5">Foundation Track</h3>
              <div class="flex flex-wrap gap-3">
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Biblical Survey</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Salvation & New Life</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Prayer & Worship</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Christian Character</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Bible Study Methods</span>
              </div>
            </div>

            <div class="flex items-center gap-2 text-slate-700 shrink-0">
              <span class="text-xl">🗓️</span>
              <span class="text-lg">3 Months</span>
            </div>
          </div>
        </div>

        <div class="rounded-[26px] border border-indigo-200 bg-indigo-50/70 p-6 md:p-8">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
            <div>
              <h3 class="text-2xl md:text-3xl font-extrabold text-gray-950 mb-5">Growth Track</h3>
              <div class="flex flex-wrap gap-3">
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Theology Basics</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Spiritual Gifts</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Ministry Skills</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Evangelism Training</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Discipleship Principles</span>
              </div>
            </div>

            <div class="flex items-center gap-2 text-slate-700 shrink-0">
              <span class="text-xl">🗓️</span>
              <span class="text-lg">6 Months</span>
            </div>
          </div>
        </div>

        <div class="rounded-[26px] border border-purple-200 bg-purple-50/70 p-6 md:p-8">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
            <div>
              <h3 class="text-2xl md:text-3xl font-extrabold text-gray-950 mb-5">Leadership Track</h3>
              <div class="flex flex-wrap gap-3">
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Advanced Theology</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Leadership Development</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Teaching & Preaching</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Pastoral Care</span>
                <span class="px-4 py-2 rounded-full bg-white text-slate-700 text-base">Ministry Management</span>
              </div>
            </div>

            <div class="flex items-center gap-2 text-slate-700 shrink-0">
              <span class="text-xl">🗓️</span>
              <span class="text-lg">6 Months</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WEEKLY SCHEDULE -->
  <section class="py-12 md:py-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-indigo-50/70 border border-indigo-100 p-8 md:p-10">
        <h2 class="text-4xl md:text-5xl font-extrabold text-gray-950 mb-8">
          Weekly Schedule
        </h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="rounded-[24px] bg-white p-6 md:p-7 shadow-sm">
            <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Tuesday Evening Sessions</h3>
            <p class="text-xl text-slate-800 mb-3">6:00 PM - 8:00 PM</p>
            <p class="text-lg leading-relaxed text-slate-700">
              Main teaching sessions with Q&amp;A and discussion
            </p>
          </div>

          <div class="rounded-[24px] bg-white p-6 md:p-7 shadow-sm">
            <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Saturday Morning Groups</h3>
            <p class="text-xl text-slate-800 mb-3">9:00 AM - 11:00 AM</p>
            <p class="text-lg leading-relaxed text-slate-700">
              Small group mentorship and practical assignments
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pt-4 pb-20 md:pb-24">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-gradient-to-r from-[#4F46E5] via-[#9333EA] to-[#C026D3] px-8 md:px-12 py-12 md:py-14 text-white text-center shadow-sm">
        <h2 class="text-4xl md:text-5xl font-extrabold mb-5">
          Ready to Begin Your Journey?
        </h2>
        <p class="max-w-4xl mx-auto text-lg md:text-2xl leading-relaxed text-white/95 mb-8">
          Join Discipleship by the Word and experience transformative biblical training that will equip you for a lifetime of fruitful ministry.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
             href="/contact?type=registration&target=Discipleship%20by%20the%20Word#contact-form-section"
             class="inline-flex items-center justify-center gap-3 rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg font-semibold shadow-sm hover:shadow-md transition min-w-[190px]"
                >
                  Register Now
              <span class="text-2xl leading-none">→</span>
          </a>

          <a
            href="/hub"
            class="inline-flex items-center justify-center gap-3 rounded-2xl border border-white/20 bg-white/10 text-white px-8 py-4 text-lg font-semibold hover:bg-white/15 transition min-w-[210px]"
          >
            Browse Courses
            <span class="text-2xl leading-none">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

 <%- include("../partials/auth-modal") %>
<script src="/js/auth-modal.js"></script>

</body>
</html>