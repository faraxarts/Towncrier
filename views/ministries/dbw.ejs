<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Discipleship by the Word | Town Crier</title>

  <link rel="icon" type="image/png" href="/images/tcem-logo.png" />
  <link rel="apple-touch-icon" href="/images/tcem-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />

  <style>
    .dbw-page {
      background: #f7f7f8;
      color: #111827;
      font-family: "Inter", sans-serif;
    }

    .dbw-subnav-link {
      font-family: "Inter", sans-serif;
    }

    .dbw-hero-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(3.2rem, 6vw, 5.6rem);
      line-height: 0.92;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 1.25rem;
    }

    .dbw-hero-text {
      font-family: "Inter", sans-serif;
      font-size: clamp(1.05rem, 2vw, 1.45rem);
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.96);
    }

    .dbw-section-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(2.5rem, 4vw, 4rem);
      line-height: 0.96;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #111827;
    }

    .dbw-card-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(2rem, 3vw, 2.7rem);
      line-height: 1;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #111827;
    }

    .dbw-track-title {
      font-family: "Cormorant Garamond", serif;
      font-size: clamp(2rem, 3vw, 2.5rem);
      line-height: 1;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #111827;
    }

    .dbw-body-text {
      font-family: "Inter", sans-serif;
      font-size: 1.05rem;
      line-height: 1.85;
      color: #475569;
    }

    .dbw-meta-text {
      font-family: "Inter", sans-serif;
      font-size: 1rem;
      line-height: 1.7;
      color: #64748b;
    }

    .dbw-pill {
      font-family: "Inter", sans-serif;
      font-size: 0.95rem;
      line-height: 1.2;
      font-weight: 500;
    }

    .dbw-button-text {
      font-family: "Inter", sans-serif;
      font-weight: 700;
      letter-spacing: 0.01em;
    }

    @media (max-width: 767px) {
      .dbw-hero-title {
        font-size: clamp(2.7rem, 12vw, 4rem);
      }

      .dbw-hero-text {
        font-size: 1rem;
        line-height: 1.75;
      }

      .dbw-body-text {
        font-size: 1rem;
        line-height: 1.75;
      }

      .dbw-pill {
        font-size: 0.9rem;
      }
    }
  </style>
</head>
<body class="dbw-page">

  <%- include("../partials/header") %>

  <!-- MINISTRIES SUB NAV -->
  <section class="border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="flex items-center gap-8 overflow-x-auto">
        <a href="/ministries/dbw" class="dbw-subnav-link inline-flex h-14 items-center border-b-2 border-[#4F46E5] text-[#4F46E5] font-semibold whitespace-nowrap">
          Discipleship by the Word
        </a>
        <a href="/ministries/bootcamp" class="dbw-subnav-link inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#4F46E5] whitespace-nowrap transition">
          Discipleship Bootcamp
        </a>
        <a href="/ministries/arrows" class="dbw-subnav-link inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#4F46E5] whitespace-nowrap transition">
          Arrows in the Quiver
        </a>
      </div>
    </div>
  </section>

  <!-- HERO -->
  <section class="py-12 md:py-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-gradient-to-r from-[#4F46E5] via-[#9333EA] to-[#EC4899] px-8 md:px-12 py-12 md:py-16 text-white shadow-sm">
        <div class="max-w-4xl">
          <h1 class="dbw-hero-title">
            Discipleship by the Word
          </h1>

          <p class="dbw-hero-text mb-8">
            Discipleship by the Word [DBW] is a structured discipleship ministry under Town Crier Evangelical Ministries [TCEM], established by Livingstone Favour Akinadewo in September 2022. Its purpose is to raise and form believers through biblical study, prayer, reflection, assignments, cell-group discipleship, and practical evangelistic work.
          </p>

          <a
            href="/contact?type=registration&target=Discipleship%20by%20the%20Word#contact-form-section"
            class="dbw-button-text inline-flex items-center gap-3 rounded-2xl bg-white text-[#4F46E5] px-7 py-4 text-lg shadow-sm hover:shadow-md transition"
          >
            Join our Discipleship group
            <span class="text-2xl leading-none">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION + APPROACH -->
  <section class="pb-12 md:pb-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
          <div class="w-14 h-14 rounded-2xl bg-indigo-100 flex items-center justify-center mb-7">
            <span class="text-2xl">🎯</span>
          </div>

          <h2 class="dbw-section-title mb-5">
            Our Mission
          </h2>

          <p class="dbw-body-text">
            To raise up biblically grounded disciples who understand God's Word, live by its principles, and effectively minister to others. We focus on systematic Bible teaching, practical application, and spiritual formation.
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
          <div class="w-14 h-14 rounded-2xl bg-purple-100 flex items-center justify-center mb-7">
            <span class="text-2xl">📖</span>
          </div>

          <h2 class="dbw-section-title mb-5">
            Our Approach
          </h2>

          <p class="dbw-body-text">
            We use a blend of classroom teaching, small group discussions, mentorship, and practical ministry assignments. Our curriculum covers biblical foundations, theology, spiritual disciplines, and ministry skills.
          </p>
        </div>

      </div>
    </div>
  </section>

  
  
  <!-- WEEKLY SCHEDULE -->
  <section class="py-12 md:py-14">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-indigo-50/70 border border-indigo-100 p-8 md:p-10">
        <h2 class="dbw-section-title mb-8">
          Weekly Schedule
        </h2>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="rounded-[24px] bg-white p-6 md:p-7 shadow-sm">
            <h3 class="dbw-card-title mb-3">Tuesday Evening Sessions</h3>
            <p class="dbw-meta-text mb-3">6:00 PM - 8:00 PM</p>
            <p class="dbw-body-text">
              Main teaching sessions with Q&amp;A and discussion
            </p>
          </div>

          <div class="rounded-[24px] bg-white p-6 md:p-7 shadow-sm">
            <h3 class="dbw-card-title mb-3">Saturday Morning Groups</h3>
            <p class="dbw-meta-text mb-3">9:00 AM - 11:00 AM</p>
            <p class="dbw-body-text">
              Small group mentorship and practical assignments
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pt-4 pb-20 md:pb-24">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="rounded-[30px] bg-gradient-to-r from-[#4F46E5] via-[#9333EA] to-[#C026D3] px-8 md:px-12 py-12 md:py-14 text-white text-center shadow-sm">
        <h2 class="dbw-section-title text-white mb-5">
  Ready to Begin Your Journey?
</h2>

        <p class="dbw-hero-text max-w-4xl mx-auto mb-8">
          Join Discipleship by the Word and experience transformative biblical training that will equip you for a lifetime of fruitful ministry.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/contact?type=registration&target=Discipleship%20by%20the%20Word#contact-form-section"
            class="dbw-button-text inline-flex items-center justify-center gap-3 rounded-2xl bg-white text-[#4F46E5] px-8 py-4 text-lg shadow-sm hover:shadow-md transition min-w-[190px]"
          >
            Register Now
            <span class="text-2xl leading-none">→</span>
          </a>

          <a
            href="/hub"
            class="dbw-button-text inline-flex items-center justify-center gap-3 rounded-2xl border border-white/20 bg-white/10 text-white px-8 py-4 text-lg hover:bg-white/15 transition min-w-[210px]"
          >
            Browse Courses
            <span class="text-2xl leading-none">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <%- include("../partials/auth-modal") %>
  <script src="/js/auth-modal.js"></script>

</body>
</html>