<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact | Town Crier</title>
  <link rel="icon" type="image/png" href="/images/tcem-logo.png" />
<link rel="apple-touch-icon" href="/images/tcem-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("partials/header") %>

  <!-- CONNECT SUB NAV -->
  <section class="border-b border-gray-200 bg-transparent">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="flex items-center gap-8 overflow-x-auto">
        <a href="/events" class="inline-flex h-14 items-center border-b-2 border-transparent text-gray-700 font-medium hover:text-[#4F46E5] whitespace-nowrap transition">
          Events
        </a>
        <a href="/contact" class="inline-flex h-14 items-center border-b-2 border-[#4F46E5] text-[#4F46E5] font-semibold whitespace-nowrap">
          Contact
        </a>
      </div>
    </div>
  </section>

  <!-- HERO -->
  <section class="pt-10 md:pt-14 pb-14 md:pb-16">
    <div class="max-w-7xl mx-auto px-6 md:px-16 text-center">
      <h1 id="page-heading" class="text-4xl md:text-6xl font-extrabold tracking-tight text-gray-950 mb-5">
        Contact & Prayer
      </h1>
      <p id="page-subtitle" class="text-lg md:text-2xl text-slate-600 max-w-4xl mx-auto leading-relaxed">
        We would love to hear from you. Reach out for inquiries, fellowship, support, or prayer requests.
      </p>
    </div>
  </section>

  <!-- CONTACT INFO CARDS -->
  <section class="pb-14 md:pb-16">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">

        <div class="bg-white border border-gray-100 rounded-[24px] shadow-sm p-7">
          <div class="w-14 h-14 rounded-2xl bg-indigo-100 flex items-center justify-center mb-6 text-2xl">
            📍
          </div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Visit Us</h3>
          <p class="text-slate-700 text-lg leading-relaxed">
            Main Sanctuary,<br>
            Town Crier Evangelical Ministries,<br>
            Your City, Nigeria
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[24px] shadow-sm p-7">
          <div class="w-14 h-14 rounded-2xl bg-purple-100 flex items-center justify-center mb-6 text-2xl">
            📞
          </div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Call Us</h3>
          <p class="text-slate-700 text-lg leading-relaxed">
            +234 800 000 0000<br>
            +234 900 000 0000
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[24px] shadow-sm p-7">
          <div class="w-14 h-14 rounded-2xl bg-pink-100 flex items-center justify-center mb-6 text-2xl">
            ✉️
          </div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Email</h3>
          <p class="text-slate-700 text-lg leading-relaxed break-words">
            hello@towncrier.org<br>
            prayer@towncrier.org
          </p>
        </div>

        <div class="bg-white border border-gray-100 rounded-[24px] shadow-sm p-7">
          <div class="w-14 h-14 rounded-2xl bg-emerald-100 flex items-center justify-center mb-6 text-2xl">
            🕒
          </div>
          <h3 class="text-2xl font-extrabold text-gray-950 mb-3">Service Times</h3>
          <p class="text-slate-700 text-lg leading-relaxed">
            Sundays: 9:00 AM & 11:00 AM<br>
            Wednesdays: 6:00 PM<br>
            Fridays: 5:00 AM
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- FORM + QUICK CONTACT -->
  <section id="contact-form-section" class="scroll-mt-28 pb-16 md:pb-20">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="grid grid-cols-1 xl:grid-cols-5 gap-8">

        <!-- FORM -->
        <div class="xl:col-span-3 bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-10">
          <% if (typeof submitted !== "undefined" && submitted === "success") { %>
            <div class="mb-6 rounded-2xl border border-green-200 bg-green-50 px-5 py-4 text-green-700 font-medium">
              Your form was submitted successfully. Our team will get back to you soon.
            </div>
          <% } %>

          <div class="mb-8">
            <h2 id="form-heading" class="text-3xl md:text-4xl font-extrabold text-gray-950 mb-3">
              Send Us a Message
            </h2>
            <p id="form-subtitle" class="text-lg text-slate-600 leading-relaxed">
              Fill in the form below and we’ll get back to you as soon as possible.
            </p>
          </div>

          <form id="contact-form" action="/contact/submit" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="fullName" class="block text-sm font-semibold text-gray-800 mb-2">Full Name</label>
                <input
                  type="text"
                  id="fullName"
                  name="fullName"
                  class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3.5 text-gray-900 outline-none focus:border-[#6B46C1] focus:ring-2 focus:ring-purple-100 transition"
                  placeholder="Enter your full name"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-gray-800 mb-2">Email Address</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3.5 text-gray-900 outline-none focus:border-[#6B46C1] focus:ring-2 focus:ring-purple-100 transition"
                  placeholder="Enter your email"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="block text-sm font-semibold text-gray-800 mb-2">Phone Number</label>
                <input
                  type="text"
                  id="phone"
                  name="phone"
                  class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3.5 text-gray-900 outline-none focus:border-[#6B46C1] focus:ring-2 focus:ring-purple-100 transition"
                  placeholder="Enter your phone number"
                />
              </div>

              <div>
                <label for="category" class="block text-sm font-semibold text-gray-800 mb-2">Category</label>
                <select
                  id="category"
                  name="category"
                  class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3.5 text-gray-900 outline-none focus:border-[#6B46C1] focus:ring-2 focus:ring-purple-100 transition"
                >
                  <option value="">Select a category</option>
                  <option value="Registration">Registration</option>
                  <option value="General Inquiry">General Inquiry</option>
                  <option value="Prayer Request">Prayer Request</option>
                  <option value="Counselling">Counselling</option>
                  <option value="Partnership">Partnership</option>
                  <option value="Volunteer Request">Volunteer Request</option>
                </select>
              </div>
            </div>

            <div id="program-field-wrapper" class="hidden">
              <label for="programTarget" class="block text-sm font-semibold text-gray-800 mb-2">Program / Ministry</label>
              <select
                id="programTarget"
                name="programTarget"
                class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3.5 text-gray-900 outline-none focus:border-[#6B46C1] focus:ring-2 focus:ring-purple-100 transition"
              >
                <option value="">Select a program</option>
                <option value="Discipleship by the Word">Discipleship by the Word</option>
                <option value="Discipleship Bootcamp">Discipleship Bootcamp</option>
                <option value="Arrows in the Quiver">Arrows in the Quiver</option>
                <option value="DBW HUB">DBW HUB</option>
              </select>
            </div>

            <div>
              <label for="subject" class="block text-sm font-semibold text-gray-800 mb-2">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3.5 text-gray-900 outline-none focus:border-[#6B46C1] focus:ring-2 focus:ring-purple-100 transition"
                placeholder="Enter message subject"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-gray-800 mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="7"
                class="w-full rounded-2xl border border-gray-200 bg-white px-4 py-3.5 text-gray-900 outline-none focus:border-[#6B46C1] focus:ring-2 focus:ring-purple-100 transition resize-none"
                placeholder="Write your message here..."
              ></textarea>
            </div>

            <button
              id="submit-button"
              type="submit"
              class="inline-flex items-center justify-center rounded-full bg-[#6B46C1] text-white px-8 py-4 font-bold text-lg shadow-md hover:bg-purple-700 transition"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- SIDE PANEL -->
        <div class="xl:col-span-2 space-y-8">
          <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8">
            <h3 class="text-2xl md:text-3xl font-extrabold text-gray-950 mb-4">
              Need Prayer?
            </h3>
            <p class="text-lg text-slate-700 leading-relaxed mb-6">
              We believe in the power of prayer. Share your prayer request with us and our team will stand with you in faith.
            </p>

            <div class="space-y-4">
              <a
                href="#"
                class="w-full inline-flex items-center justify-center gap-3 rounded-2xl bg-[#08C443] text-white px-6 py-4 text-lg font-semibold hover:opacity-95 transition"
              >
                <span class="text-xl">🟢</span>
                WhatsApp Prayer Line
              </a>

              <a
                href="#"
                class="w-full inline-flex items-center justify-center gap-3 rounded-2xl bg-[#3B82F6] text-white px-6 py-4 text-lg font-semibold hover:opacity-95 transition"
              >
                <span class="text-xl">✈️</span>
                Telegram Community
              </a>
            </div>
          </div>

          <div class="bg-gradient-to-r from-[#4F46E5] via-[#A855F7] to-[#EC4899] rounded-[28px] p-8 text-white shadow-sm">
            <h3 class="text-2xl md:text-3xl font-extrabold mb-4">
              Fellowship With Us
            </h3>
            <p class="text-lg leading-relaxed text-white/95 mb-6">
              Join us physically or online and be part of a growing community passionate about Christ, discipleship, and kingdom impact.
            </p>

            <div class="space-y-3 text-base md:text-lg text-white/95">
              <p><strong>Sunday Worship:</strong> 9:00 AM & 11:00 AM</p>
              <p><strong>Bible Study:</strong> Wednesdays, 6:00 PM</p>
              <p><strong>Prayer Meeting:</strong> Fridays, 5:00 AM</p>
            </div>
          </div>

          <div class="bg-white border border-gray-100 rounded-[28px] shadow-sm p-8">
            <h3 class="text-2xl md:text-3xl font-extrabold text-gray-950 mb-4">
              Office Hours
            </h3>
            <div class="space-y-3 text-lg text-slate-700">
              <p><strong>Monday - Friday:</strong> 9:00 AM - 5:00 PM</p>
              <p><strong>Saturday:</strong> 10:00 AM - 2:00 PM</p>
              <p><strong>Sunday:</strong> Service hours only</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <%- include("partials/footer") %>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const params = new URLSearchParams(window.location.search);

      const type = params.get("type");
      const target = params.get("target");

      const pageHeading = document.getElementById("page-heading");
      const pageSubtitle = document.getElementById("page-subtitle");
      const formHeading = document.getElementById("form-heading");
      const formSubtitle = document.getElementById("form-subtitle");
      const category = document.getElementById("category");
      const subject = document.getElementById("subject");
      const message = document.getElementById("message");
      const submitButton = document.getElementById("submit-button");
      const programFieldWrapper = document.getElementById("program-field-wrapper");
      const programTarget = document.getElementById("programTarget");

      function showProgramField() {
        programFieldWrapper.classList.remove("hidden");
      }

      function hideProgramField() {
        programFieldWrapper.classList.add("hidden");
      }

      function ensureProgramOption(value) {
        if (!value) return;

        const exists = Array.from(programTarget.options).some(
          (option) => option.value === value
        );

        if (!exists) {
          const newOption = document.createElement("option");
          newOption.value = value;
          newOption.textContent = value;
          programTarget.appendChild(newOption);
        }
      }

      function applyRegistrationMode(targetValue) {
        const cleanTarget = targetValue || "Town Crier Program";

        pageHeading.textContent = `Register for ${cleanTarget}`;
        pageSubtitle.textContent = "Complete the form below to register your interest and our team will follow up with you.";
        formHeading.textContent = "Registration Form";
        formSubtitle.textContent = "Your selected program has already been prepared in the form below.";
        submitButton.textContent = "Complete Registration";

        category.value = "Registration";
        showProgramField();

        ensureProgramOption(cleanTarget);
        programTarget.value = cleanTarget;

        if (!subject.value) {
          subject.value = `Registration for ${cleanTarget}`;
        }

        if (!message.value) {
          message.value = `Hello, I would like to register for ${cleanTarget}.`;
        }
      }

      category.addEventListener("change", function () {
        if (this.value === "Registration") {
          showProgramField();
        } else {
          hideProgramField();
          programTarget.value = "";
        }
      });

      if (type === "registration") {
        applyRegistrationMode(target);
      } else if (category.value === "Registration") {
        showProgramField();
      }
    });
  </script>

</body>
</html>