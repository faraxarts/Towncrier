<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About | Town Crier</title>
  <link rel="icon" type="image/png" href="/images/tcem-logo.png" />
<link rel="apple-touch-icon" href="/images/tcem-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="bg-[#f7f7f8] text-gray-900">

  <%- include("partials/header") %>

  <section class="about-page-hero">
  <div class="max-w-7xl mx-auto px-6 md:px-16">
    <div
      class="about-page-hero__panel"
      style="background-image: url('/images/here.jpg');"
    >
      <div class="about-page-hero__overlay"></div>

      <div class="about-page-hero__content">
        <p class="about-page-hero__kicker">About</p>

        <h1 class="about-page-hero__title">
          About Town Crier Evangelical Ministries
        </h1>

        <p class="about-page-hero__text">
          This is an Oak of Righteousness, the planting of the Lord, that He might be glorified.
        </p>
      </div>
    </div>
  </div>
</section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-6 md:px-16">
      <div class="max-w-4xl mx-auto bg-white border border-gray-100 rounded-[28px] shadow-sm p-8 md:p-12">
        <h2 class="text-3xl md:text-5xl font-extrabold text-gray-950 mb-8">
          Who We Are
        </h2>

        <div class="space-y-8 text-lg md:text-[1.45rem] leading-relaxed text-slate-700">
          <p>
            Town Crier Evangelical Ministries is a para-church organisation with the mandate of discipling true christians, stewarding revival and undertaking evangelistic missions across the Nations! This is an oak of righteousness; a planting of the Lord. We operate mainly through the systematic teaching of the Word via sound doctrine, discipling teenagers and adults both locally and internationally. 
          </p>

          <p>
            Founded on the unchanging truth of God's Word, we believe that the hope of God, creation and human-kind lies in the emergence of sons; men and women who are christians at heart and in character. To achieve this end, we employ the intense workings of the Spirit of Life, prayer regimens and evangelistic field works, making use of both onsite and online media as a catalyst to raise accurate christians, setting generations ablaze for Jesus!  
            Our ministry is characterized by authentic worship, sound doctrine, genuine fellowship,
            and compassionate service.
          </p>
           <p>
            This is Bethlehem; The House Of Bread. 
          </p>
        </div>
      </div>
    </div>
  </section>

<section class="pb-16 md:pb-20">
  <div class="max-w-7xl mx-auto px-6 md:px-16">
    <div class="about-lead-shell">
      <div class="about-lead-media">
        <div class="about-lead-image-card">
          <img
            src="/images/meet_lead.JPG"
            alt="Livingstone Akinadewo"
            class="about-lead-image"
          />

          <div class="about-lead-image-overlay">
            <p class="about-lead-image-caption">Livingstone F. Akinadewo</p>
          </div>
        </div>
      </div>

      <div class="about-lead-copy">
        <p class="about-lead-kicker">Ministry Lead</p>

        <h2 class="home-serif-title about-lead-title">
          Meet <%= leadProfile.name %>
        </h2>

        <p class="about-lead-role">Lead Evangelist / President</p>

        <p class="about-lead-text">
          <%= leadProfile.excerpt %>
        </p>

        <a
          href="/livingstone-akinadewo"
          class="home-primary-button"
        >
          Meet Livingstone Akinadewo →
        </a>
      </div>
    </div>
  </div>
</section>

  <section class="pb-16 md:pb-20">
  <div class="max-w-7xl mx-auto px-6 md:px-16">
    <div class="about-purpose-shell">
      <div class="about-purpose-vision">
        <p class="about-purpose-label">Our Vision</p>
        <div class="about-purpose-accent"></div>

        <div class="about-purpose-quote-wrap">
          <span class="about-purpose-quote-mark">“</span>

          <p class="about-purpose-vision-text">
            Striving to attain multiplication of the God-kind by raising leaders who will be fruitful with their training and in turn begin to multiple their (our) kind. Altogether, fruitfulness with the seed of eternal life and multiplication of the God-kind nature is our overall goal.
          </p>

          <span class="about-purpose-quote-mark about-purpose-quote-mark--end">”</span>
        </div>
      </div>

      <div class="about-purpose-mission">
        <p class="about-purpose-label">Our Mission</p>
        <div class="about-purpose-accent"></div>

        <div class="about-purpose-mission-body">
          <p>
            Under the leadership of our Lord Jesus Christ and the stewardship of the President, TCEM is ran by a committee of leaders; devout men and women who believes in the Heavenly vision, striving together with the head for its accomplishment, giving themselves thoroughly to the minsitry of the Word and prayer as the Holy Spirit enables them to multiply the God-kind.
          </p>

          <p>
            2 Timothy 2:2 says, "And the things that thou hast heard of me among many witnesses, the same commit thou to faithful men, who shall be able to teach others also." The above Scripture is the clear revelation of our mission, and the true secret to fruitfulness and multiplication. With the help of a team of willing, yielded and faifthful men, we birth this mission into reality.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

  

<%
  const safeVideoTitle =
    typeof ministryVideoTitle !== "undefined" && ministryVideoTitle
      ? ministryVideoTitle
      : "Learn More About the Ministry";

  const safeVideoText =
    typeof ministryVideoText !== "undefined" && ministryVideoText
      ? ministryVideoText
      : "Watch these videos to learn more about the ministry.";

  const safeVideos =
    typeof ministryVideos !== "undefined" && Array.isArray(ministryVideos)
      ? ministryVideos
      : [];
%>

<section class="py-16 md:py-20 bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-16">
    <div class="text-center max-w-3xl mx-auto mb-10">
      <p class="text-sm font-semibold uppercase tracking-wide text-[#6B46C1] mb-3">
        Ministry Story
      </p>

      <h2 class="text-3xl md:text-5xl font-extrabold text-gray-950 mb-5 leading-tight">
        <%= safeVideoTitle %>
      </h2>

      <p class="text-lg md:text-xl leading-relaxed text-slate-700">
        <%= safeVideoText %>
      </p>
    </div>

    <% if (safeVideos.length) { %>
      <div class="about-video-wrapper">
        <div id="about-video-carousel" class="about-video-stage">
          <% safeVideos.forEach((video, index) => { %>
            <div
              class="about-video-slide <%= index === 0 ? 'is-active' : '' %>"
              data-index="<%= index %>"
            >
              <div class="about-video-card">
                <div class="about-video-frame">
                  <iframe
                    src="<%= video.embedUrl %>"
                    title="<%= video.title %>"
                    class="about-video-iframe"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>

                <div class="about-video-caption">
                  <p class="text-base md:text-lg font-bold text-gray-900">
                    <%= video.title %>
                  </p>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="about-video-dots">
          <% safeVideos.forEach((video, index) => { %>
            <button
              type="button"
              class="about-video-dot <%= index === 0 ? 'is-active' : '' %>"
              data-index="<%= index %>"
              aria-label="Go to video <%= index + 1 %>"
            ></button>
          <% }) %>
        </div>
      </div>
    <% } else { %>
      <div class="rounded-[28px] border border-dashed border-gray-300 bg-gray-50 p-10 text-center">
        <p class="text-lg text-slate-600">
          Ministry videos will appear here once added.
        </p>
      </div>
    <% } %>
  </div>
</section>

<style>
  .about-page-hero {
  padding: 2rem 0 4rem;
  background: #f7f7f8;
}

.about-page-hero__panel {
  position: relative;
  min-height: 560px;
  border-radius: 34px;
  overflow: hidden;
  background-size: cover;
  background-position: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 22px 50px rgba(15, 23, 42, 0.08);
}

.about-page-hero__overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.14) 0%, rgba(15, 23, 42, 0.26) 42%, rgba(107, 70, 193, 0.72) 100%),
    linear-gradient(90deg, rgba(107, 70, 193, 0.48) 0%, rgba(107, 70, 193, 0.12) 20%, rgba(107, 70, 193, 0) 34%),
    linear-gradient(270deg, rgba(107, 70, 193, 0.34) 0%, rgba(107, 70, 193, 0) 18%);
}

.about-page-hero__content {
  position: relative;
  z-index: 1;
  text-align: center;
  color: #ffffff;
  max-width: 860px;
  padding: 2.5rem 1.5rem;
}

.about-page-hero__kicker {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.22em;
  margin-bottom: 0.9rem;
  color: rgba(255, 255, 255, 0.85);
}

.about-page-hero__title {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(2.4rem, 5vw, 4.7rem);
  line-height: 0.98;
  font-weight: 700;
  margin-bottom: 1rem;
  color: #ffffff;
}

.about-page-hero__text {
  max-width: 760px;
  margin: 0 auto;
  font-size: 1.05rem;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.94);
}

.about-purpose-shell {
  display: grid;
  grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
  gap: 2.5rem;
  align-items: start;
  background: #ffffff;
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 30px;
  box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
  padding: 2rem;
}

.about-purpose-label {
  font-size: 0.76rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: #6B46C1;
}

.about-purpose-accent {
  width: 92px;
  height: 4px;
  border-radius: 999px;
  margin: 0.9rem 0 1.2rem;
  background: linear-gradient(90deg, rgba(107, 70, 193, 0.18), #6B46C1, rgba(107, 70, 193, 0.18));
}

.about-purpose-quote-wrap {
  position: relative;
}

.about-purpose-quote-mark {
  display: block;
  font-family: "Cormorant Garamond", serif;
  font-size: 3.8rem;
  line-height: 1;
  color: #6B46C1;
  font-weight: 700;
}

.about-purpose-quote-mark--end {
  text-align: right;
  margin-top: 0.35rem;
}

.about-purpose-vision-text {
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(1.7rem, 3vw, 2.55rem);
  line-height: 1.14;
  font-weight: 700;
  font-style: italic;
  color: #4a2c67;
  max-width: 480px;
}

.about-purpose-mission-body {
  border-left: 4px solid rgba(107, 70, 193, 0.78);
  padding-left: 1.2rem;
}

.about-purpose-mission-body p {
  color: #475569;
  font-size: 1rem;
  line-height: 1.9;
  margin-bottom: 1rem;
}

.about-purpose-mission-body p:last-child {
  margin-bottom: 0;
}

.about-lead-shell {
  display: grid;
  grid-template-columns: minmax(280px, 0.88fr) minmax(0, 1.12fr);
  gap: 2.2rem;
  align-items: center;
  background: #fffdf9;
  border: 1px solid rgba(107, 70, 193, 0.1);
  border-radius: 30px;
  box-shadow: 0 18px 42px rgba(15, 23, 42, 0.06);
  padding: 2rem;
}

.about-lead-image-card {
  position: relative;
  border-radius: 30px;
  overflow: hidden;
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
}

.about-lead-image {
  width: 100%;
  height: 460px;
  object-fit: cover;
}

.about-lead-image-overlay {
  position: absolute;
  inset: auto 0 0 0;
  padding: 1.2rem 1.3rem;
  background: linear-gradient(to top, rgba(15, 23, 42, 0.75), rgba(15, 23, 42, 0.08), transparent);
}

.about-lead-image-caption {
  color: #ffffff;
  font-size: 1rem;
  font-weight: 600;
}

.about-lead-kicker {
  color: #b3834d;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.about-lead-title {
  margin-bottom: 0.8rem;
}

.about-lead-role {
  color: #6B46C1;
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.about-lead-text {
  color: #4b5563;
  font-size: 1rem;
  line-height: 1.95;
  margin-bottom: 1.4rem;
  max-width: 640px;
}

@media (max-width: 1023px) {
  .about-purpose-shell,
  .about-lead-shell {
    grid-template-columns: 1fr;
  }

  .about-lead-image {
    height: 360px;
  }
}

@media (max-width: 767px) {
  .about-page-hero {
    padding: 1.25rem 0 3rem;
  }

  .about-page-hero__panel {
    min-height: 320px;
    border-radius: 24px;
  }

  .about-page-hero__content {
    padding: 2rem 1rem;
  }

  .about-page-hero__text {
    font-size: 0.95rem;
  }

  .about-purpose-shell,
  .about-lead-shell {
    padding: 1.35rem;
    border-radius: 24px;
  }

  .about-purpose-vision-text {
    font-size: 1.55rem;
  }

  .about-lead-image {
    height: 300px;
  }
}


  .about-video-wrapper {
    position: relative;
  }

  .about-video-stage {
    position: relative;
    min-height: 340px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .about-video-slide {
    position: absolute;
    top: 0;
    left: 50%;
    width: min(88vw, 680px);
    transform: translateX(-50%) scale(0.78);
    opacity: 0.35;
    z-index: 1;
    pointer-events: none;
    transition: transform 0.7s ease, opacity 0.7s ease;
  }

  .about-video-slide.is-active {
    transform: translateX(-50%) scale(1);
    opacity: 1;
    z-index: 3;
    pointer-events: auto;
  }

  .about-video-slide.is-prev {
    transform: translateX(-118%) scale(0.82);
    opacity: 0.7;
    z-index: 2;
  }

  .about-video-slide.is-next {
    transform: translateX(18%) scale(0.82);
    opacity: 0.7;
    z-index: 2;
  }

  .about-video-slide.is-hidden-left {
    transform: translateX(-165%) scale(0.65);
    opacity: 0;
    z-index: 0;
  }

  .about-video-slide.is-hidden-right {
    transform: translateX(65%) scale(0.65);
    opacity: 0;
    z-index: 0;
  }

  .about-video-card {
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
  }

  .about-video-frame {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #000;
  }

  .about-video-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .about-video-caption {
    padding: 1rem 1.25rem 1.1rem;
  }

  .about-video-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .about-video-dot {
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background: #d1d5db;
    transition: all 0.3s ease;
  }

  .about-video-dot.is-active {
    width: 32px;
    background: #6b46c1;
  }

  @media (min-width: 768px) {
    .about-video-stage {
      min-height: 500px;
    }

    .about-video-slide {
      width: min(58vw, 720px);
    }
  }

  @media (max-width: 767px) {
    .about-video-stage {
      min-height: 290px;
    }

    .about-video-slide,
    .about-video-slide.is-prev,
    .about-video-slide.is-next,
    .about-video-slide.is-hidden-left,
    .about-video-slide.is-hidden-right {
      width: 100%;
      transform: translateX(-50%) scale(0.96);
      opacity: 0;
      z-index: 0;
      pointer-events: none;
    }

    .about-video-slide.is-active {
      width: 100%;
      transform: translateX(-50%) scale(1);
      opacity: 1;
      z-index: 3;
      pointer-events: auto;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const carousel = document.getElementById("about-video-carousel");
    if (!carousel) return;

    const slides = Array.from(carousel.querySelectorAll(".about-video-slide"));
    const dots = Array.from(document.querySelectorAll(".about-video-dot"));
    const total = slides.length;

    if (!total) return;

    let activeIndex = 0;
    let autoPlay = null;

    function getWrappedIndex(index) {
      if (index < 0) return total - 1;
      if (index >= total) return 0;
      return index;
    }

    function updateCarousel(index) {
      activeIndex = getWrappedIndex(index);

      slides.forEach((slide, i) => {
        slide.classList.remove(
          "is-active",
          "is-prev",
          "is-next",
          "is-hidden-left",
          "is-hidden-right"
        );

        const prevIndex = getWrappedIndex(activeIndex - 1);
        const nextIndex = getWrappedIndex(activeIndex + 1);

        if (i === activeIndex) {
          slide.classList.add("is-active");
        } else if (window.innerWidth >= 768 && i === prevIndex) {
          slide.classList.add("is-prev");
        } else if (window.innerWidth >= 768 && i === nextIndex) {
          slide.classList.add("is-next");
        } else if (window.innerWidth >= 768) {
          if (i < activeIndex && !(activeIndex === 0 && i === total - 1)) {
            slide.classList.add("is-hidden-left");
          } else {
            slide.classList.add("is-hidden-right");
          }
        }
      });

      dots.forEach((dot, i) => {
        if (i === activeIndex) {
          dot.classList.add("is-active");
        } else {
          dot.classList.remove("is-active");
        }
      });
    }

    function stopAutoPlay() {
      if (autoPlay) {
        clearInterval(autoPlay);
        autoPlay = null;
      }
    }

    function startAutoPlay() {
      stopAutoPlay();
      autoPlay = setInterval(() => {
        updateCarousel(activeIndex + 1);
      }, 5000);
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", function () {
        const index = Number(this.dataset.index);
        updateCarousel(index);
        startAutoPlay();
      });
    });

    window.addEventListener("resize", function () {
      updateCarousel(activeIndex);
    });

    updateCarousel(0);
    startAutoPlay();
  });
</script>
  <%- include("partials/footer") %>

</body>
</html>
